{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name" : "show",
		        "script" : [ { "anim" : "SCREEN_SHOW" } ]
		    },
		    {
		       	"name" : "hide",
		       	"script" : [ { "anim" : "SIMPLE_SCREEN_HIDE" } ]
	      }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$Bg_Kick"
        },
        {
            "commonName": "Panel",
            "name": "UIFrame",
            "alignV": "CENTER",
            "alignH": "FILL",
            "height": 580,
            "children":
            [
                {
                    "commonName": "GestureArea",
                    "name": "gestureArea",
                    "alignH": "FILL",
                    "alignV": "FILL",
                    "swipeAction":
                    {
                        "action": "act_swipe",
                        "binding": "bnd_swipe"
                    },
                    "bindings":
                    [
                        {
                            "binding": "BND_SCREEN_HEIGHT",
                            "property": "height"
                        },
                        {
                            "binding": "BND_SCREEN_WIDTH",
                            "property": "width"
                        }
                    ]
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 10,
                    "marginLeft": 70,
                    "height": 40,
                    "width": 130,
                    "type": "$Icon_FC"
                },
                {
                    "commonName": "GenericButton",
                    "alignH": "LEFT",
                    "alignV": "BOTTOM",
                    "marginBottom": 0,
                    "marginLeft": 30,
                    "scaleX": 0.6,
                    "scaleY": 0.6,
                    "icon": "$SimMatchIcon2",
                    "clickAction": "act_back"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 0,
                    "marginLeft": 86,
                    "fontSize": 14,
                    "fontColor": "$COLOR_LIGHT_GRAY",
                    "styles": ["TF_MATCH_REVEAL_TEAM_NAME"],
                    "text": "Back"
                },
                {
                    "commonName": "Panel",
                    "name": "MenuLayout",
                    "alignV": "TOP",
                    "alignH": "FILL",
                    "marginTop": 7,
                    "height": 30,
                    "children":
                    [
                        {
                            "commonName": "Asset",
                            "alignV": "CENTER",
                            "alignH": "LEFT",
                            "marginTop": 0,
                            "marginLeft": 60,
                            "width": 65,
                            "height": 65,
                            "type": "$Icon_Ko"
                        },
                        {
                            "commonName": "Label",
                            "name": "Live",
                            "alignV": "CENTER",
                            "alignH": "LEFT",
                            "marginTop": -2,
                            "marginLeft": 148,
                            "fontSize": 22,
                            "fontColor": "$COLOR_WHITE",
                            "fontFace": "$MONTBLANC_TRIAL_BOLD",
                            "text": "Kick Off"
                        },
                        {
                            "commonName": "Label",
                            "name": "Live",
                            "alignV": "CENTER",
                            "alignH": "LEFT",
                            "marginTop": 0,
                            "marginLeft": 257,
                            "fontSize": 25,
                            "fontColor": "$COLOR_LIGHT_GRAY",
                            "fontFace": "$FONT_ORIGIN_NORMAL",
                            "alpha": 0.3,
                            "text": "|"
                        },
                        {
                            "commonName": "Label",
                            "name": "Live",
                            "alignV": "CENTER",
                            "alignH": "LEFT",
                            "marginTop": 0,
                            "marginLeft": 299,
                            "fontSize": 22,
                            "fontColor": "$COLOR_WHITE",
                            "fontFace": "$FONT_ORIGIN_NORMAL",
                            "alpha": 0.5,
                            "bindings":
                            [
                                {
                                    "binding": "bnd_page_title",
                                    "property": "text"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "panelDataContainer",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": -20,
            "width": 580,
            "height": 350,
            "children":
            [
                {
                    "commonName": "Rectangle",
                    "name": "Backgrounds",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "color": "0x151515"
                },
                {
                    "commonName": "Rectangle",
                    "name": "BgAction",
                    "alignV": "BOTTOM",
                    "alignH": "FILL",
                    "height": 50,
                    "color": "0xFFFFFF"
                },
                {
                    "commonName": "Panel",
                    "name": "panelImage",
                    "alignV": "CENTER",
                    "alignH": "CENTER",
                    "marginTop": -25,
                    "width": 550,
                    "height": 270,
                    "children":
                    [
                        {
                            "commonName": "Image",
                            "name": "Image",
                            "alignV": "FILL",
                            "alignH": "FILL",
                            "bindings":
                            [
                                {
                                    "binding": "bnd_sub_page_image",
                                    "property": "image"
                                }
                            ],
                            "behaviors":
                            [
                                {
                                    "commonName": "ControlsHelpLoadBehavior",
                                    "actionName": "act_on_image_loaded"
                                }
                            ]
                        }
                    ]
                 },
                 {
                    "commonName": "Panel",
                    "name": "panelText",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "children":
                    [
                        {
                            "commonName": "Label",
                            "name": "Judul",
                            "alignV": "BOTTOM",
                            "alignH": "CENTER",
                            "marginLeft": 0,
                            "marginBottom": 16,
                            "fontFace": "$MONTBLANC_TRIAL_BOLD",
                            "fontColor": "$COLOR_BLACK",
                            "fontSize": 20,
                            "autoTextShadow": true,
                            "bindings":
                            [
                                {
                                    "binding": "bnd_subpage_title",
                                    "property": "text"
                                }
                            ]
                        },
                        {
                            "commonName": "Label",
                            "name": "Keterangan",
                            "alignV": "TOP",
                            "alignH": "CENTER",
                            "marginLeft": 0,
                            "marginTop": 360,
                            "fontFace": "$FONT_DINPROBOLD",
                            "fontColor": "$COLOR_WHITE",
                            "fontSize": 15,
                            "autoTextShadow": true,
                            "textAlignH": "CENTER",
                            "width": 560,
                            "multiline": true,
                            "leading": 2,
                            "bindings":
                            [
                                {
                                    "binding": "bnd_subpage_content",
                                    "property": "text"
                                }
                            ]
                        },
                        {
                            "commonName": "AssetButton",
                            "alignV": "BOTTOM",
                            "alignH": "LEFT",
                            "marginBottom": 8,
                            "marginLeft": 10,
                            "clickAction": "act_go_left",
                            "buttonAsset": "$ArrowLeft"
                        },
                        {
                            "commonName": "AssetButton",
                            "alignV": "BOTTOM",
                            "alignH": "RIGHT",
                            "marginBottom": 8,
                            "marginRight": 10,
                            "clickAction": "act_go_right",
                            "buttonAsset": "$ArrowRight"
                        }
                    ]
                }
            ]
        }
    ]
}
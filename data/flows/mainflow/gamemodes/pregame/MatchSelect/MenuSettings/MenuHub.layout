{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name" : "show",
		    "script" : [ { "anim" : "QUICK_ANIMATION_IN" } ]
	    },
	    {
			"name" : "hide",
		    "script" : [ { "anim" : "QUICK_ANIMATION_OUT" } ]
	    }
    ],
    "behaviors":
    [
        {
            "commonName": "SquadCustomizationBehavior",
            "actionName": "act_btn_click",

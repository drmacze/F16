  "alignV": "CENTER",
  "alignH": "CENTER",
  "bindings": [
    {
      "binding": "BND_SCREEN_WIDTH",
      "property": "width"
    },
    {
      "binding": "BND_SCREEN_HEIGHT",
      "property": "height"
    }
  ],
  "animationScripts": [
    {
      "name": "show",
      "script": [
        {
          "anim": "ANIMASI_MASUK_MAINMENU"
        }
      ]
    },
    {
      "name": "hide",
      "script": [
        {
          "anim": "ANIMASI_KELUAR_MAINMENU"
        }
      ]
    }
  ],

{
	"name": "QuickMatch",
    "let":  
	{ 
		"type": "friendly",
		"gamemode": "real",
		"flow": "offline",
		"flowState": "MOTM_MATCH"
	},
    "onEnter":
    [
        ["viewLayer", ["Gamemodes"]],
        ["finishViewUnload", ["screen"]],
        ["set", ["gamemode", "real"]],
        ["showFEUI", [".gamemode"]]
    ],
    "onExit":
    [
        ["hideUI", [".gamemode"]]
    ],
    "initial":
    {
        "targets": ["Pregame"]
    },
    "states":
    [
        {
            "name": "Pregame",
            "type": "external",
            "file": "/Flows/MainFlow/GameModes/PreGame/PreGame.nav",
            "outputs":
            {
                "out_exit": "out_exit_gamemode",
                "out_ingame_flow": "InGameFlow"
            }
        },
		{
			"name": "InGameFlow",
			"type": "external",
			"file": "/flows/ingameflow/ingameflow.nav",
			"outputs":
			{
				"out_exit": "out_exit_gamemode"
			}
		}
    ]
}
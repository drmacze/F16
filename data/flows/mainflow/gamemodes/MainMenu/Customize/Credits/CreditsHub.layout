                            "fillAlpha": 1,
                            "drawFill": true,
                            "drawOutline": true,
                            "outlineThickness": 0.8,
                            "outlineColor": "0x00D9D1",
                            "outlineAlpha": 1,
                            "cornerRaduis": 12
                        },
                        {

                            "backgroundHighlightImage": "$_YoutubeLogo",
                            "clickAction": "act_youtube_roberfl"
                        },
                        {
                            "commonName": "SimpleButton",
                            "alignV": "BOTTOM",
                            "alignH": "CENTER",
                            "marginBottom": 10,
                            "marginLeft": 0,
                            "width": 200,
                            "height": 43,
                            "backgroundImage": "$_InstagramLogo",
                            "backgroundHighlightImage": "$_InstagramLogo",
                            "clickAction": "act_instagram_roberfl"
                         }
                     ]

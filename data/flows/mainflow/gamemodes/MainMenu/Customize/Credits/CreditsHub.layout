                            "width": 450,
                            "fontSize": 20,
			                "fontColor": "0xFFFFFF",
			                "text": ""			  
                        },
                        {
                            "commonName": "Asset",
                            "alignH": "CENTER",
                            "alignV": "TOP",
                            "marginTop": 10,
                            "marginLeft": 0,
                            "width": 140,
                            "height": 140,
                            "visible": true,
                            "type": "$_RoberFL"
                        },

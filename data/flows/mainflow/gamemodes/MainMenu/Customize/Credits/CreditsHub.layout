{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$SimMatchIcon3",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
            "commonName": "Panel",
            "name": "MainMenu",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": 38,
            "width": 800,
            "height": 360,
            "children":
            [
                {
                    "commonName": "Rectangle",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "cornerRaduis": 13,
                    "color": "0x1B1B2A",
                    "alpha": 0.8
                },
                {
                    "commonName": "Label",
                    "alignH": "CENTER",
                    "alignV": "TOP",
                    "marginTop": 5,
                    "marginLeft": 0,
                    "autoTextShadow": true,
                    "fontSize": 25,
                    "fontFace": "$FONT_CRUYFFSANSBOLD",
                    "fontColor": "0xFFFFFF",
                    "text": "Credits"
                },
                {
                    "commonName": "Label",
                    "alignH": "CENTER",
                    "alignV": "TOP",
                    "marginTop": 38,
                    "marginLeft": 0,
                    "autoTextShadow": true,
                    "fontSize": 17,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "0xFFFFFF",
                    "text": "All credits for the DFL project should be attributed to those represented below.",

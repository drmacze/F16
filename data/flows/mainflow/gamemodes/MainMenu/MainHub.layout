/* ------------------------------------- */
/* MOD Created By Rober FL */
/* ------------------------------------- */

{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "children":
    [    
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$_Background"
        }, 
        {
            "commonName": "Image",
            "alignV": "BOTTOM",
            "alignH": "RIGHT",
            "marginRight": 0,
            "marginBottom": 0,
            "width": 650,
            "height": 650,
            "bindings":
            [
                {
                    "binding": "bnd_model",
                    "property": "image"
                }
            ]
        },     
        {
            "commonName": "SimpleButton",
            "alignH": "LEFT",
            "alignV": "BOTTOM",
            "marginBottom": 10,
            "marginLeft": 55,
            "height": 28,
            "width": 300,
            "scaleY": 1,
            "multiline": true,
            "bold": true,
            "label": "Settings / Accessibility",
            "icon": "$SimMatchIcon1",
            "backgroundImage": "",
            "backgroundHighlightImage": "",
            "clickAction": "act_customize",
            "textStyles":
            [
               "TF_BUTTON_TABON"
            ]
         },
         {
            "commonName": "SimpleButton",
            "alignH": "LEFT",
            "alignV": "BOTTOM",
            "marginBottom": 10,
            "marginLeft": 400,
            "height": 28,
            "width": 235,
            "scaleY": 1,
            "multiline": true,
            "bold": true,
            "label": "News / Updates",
            "icon": "$SimMatchIcon2",
            "backgroundImage": "",
            "backgroundHighlightImage": "",
            "clickAction": "act_news",
            "textStyles":
            [
               "TF_BUTTON_TABON"
            ]
         },
         {
            "commonName": "Panel",
            "name": "MenuLayout",
            "alignV": "TOP",
            "alignH": "FILL",
            "marginTop": 40,
            "height": 30,
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 70,
                    "fontSize": 38,
                    "fontFace": "$FONT_EAFCGAMEMODES",
	                "fontColor": "0xFFFFFF",
	                "text": "DFL"
            	},
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 65,
                    "height": 30,
                    "width": 80,
                    "clickAction": "act_to_mod_tile"
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "forceCaps": false,
                    "marginLeft": 160,
                    "fontSize": 20,
                    "fontFace": "$FONT_CRUYFFSANSBOLD",
                    "fontColor": "0xFFFFFF",
                    "text": "Home"
                },
                {
                    "commonName": "Rectangle",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 246,
                    "width": 2,
                    "height": 23,
                    "color": "0xA8A8A8",
                    "alpha": 1   
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "BagianAction",
            "alignV": "TOP",
            "alignH": "FILL",
            "marginTop": 40,
            "height": 30,
            "children":
            [
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 256,
                    "height": 30,
                    "width": 100,
                    "label": "Kick Off",
                    "clickAction": "act_tab1",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                },
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 372,
                    "height": 30,
                    "width": 115,
                    "label": "Tournaments",
                    "clickAction": "act_tab2",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                },
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 523,
                    "height": 30,
                    "width": 120,
                    "label": "Manager Career",
                    "clickAction": "act_tab3",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                },
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 682,
                    "height": 30,
                    "width": 115,
                    "label": "Player Career",
                    "clickAction": "act_tab4",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                },
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 824,
                    "height": 30,
                    "width": 105,
                    "label": "Rival Match",
                    "clickAction": "act_tab5",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                },
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 965,
                    "height": 30,
                    "width": 100,
                    "label": "Premium V3.0",
                    "clickAction": "act_tab6",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                }
             ]
          }
       ]
    }
  ]
}
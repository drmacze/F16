{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name" : "show",
		    "script" : [ { "anim" : "SCREEN_SHOW" } ]
	    },
	    {
		    "name" : "hide",
		    "script" : [ { "anim" : "SIMPLE_SCREEN_HIDE" } ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$SimMatchIcon3",
            "actionName": "act_back",
            "label": "Back"
	    }
    ],
    "children":
    [
        {
            "commonName": "Panel",
            "name": "MenuLayout",
            "alignV": "TOP",
            "alignH": "FILL",
            "marginTop": 40,
            "height": 30,
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 75,
                    "fontSize": 38,
                    "fontFace": "$FONT_EAFCGAMEMODES",
	                "fontColor": "0xFFFFFF",
	                "text": "KO"
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "forceCaps": false,
                    "marginLeft": 155,
                    "fontSize": 20,
                    "fontFace": "$FONT_CRUYFFSANSBOLD",
                    "fontColor": "0xFFFFFF",
                    "text": "Home"
                },
                {
                    "commonName": "Rectangle",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 245,
                    "width": 2,
                    "height": 23,
                    "color": "0xA8A8A8",
                    "alpha": 1
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "BagianAction",
            "alignV": "TOP",
            "alignH": "FILL",
            "marginTop": 40,
            "height": 30,
            "children":
            [
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 275,
                    "height": 30,
                    "width": 110,
                    "label": "Classic Match",
                    "clickAction": "act_tab1",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                },
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 425,
                    "height": 30,
                    "width": 180,
                    "label": "UEFA Champions League",
                    "clickAction": "act_tab2",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                },
                {
                    "commonName": "SimpleButton",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 665,
                    "height": 30,
                    "width": 180,
                    "label": "CONMEBOL Libertadores",
                    "clickAction": "act_tab3",
                    "textStyles": [ "TF_BUTTON_PLAYMODEOFF" ]
                }
             ]
          }
       ]
    }
  ]
}
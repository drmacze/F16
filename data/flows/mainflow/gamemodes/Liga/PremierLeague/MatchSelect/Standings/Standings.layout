{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
       "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "",
            "actionName": "act_back",
            "label": ""
        }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$_TestBg1"
        },
        {
            "commonName": "Panel",
            "name": "Back",
            "alignV": "FILL",
            "alignH": "FILL",
            "children":
            [
                {
                    "commonName": "GenericButton",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": -2,
                    "marginLeft": 50,
                    "height": 50,
                    "width": 50,
                    "label": "",
                    "icon": "$SimMatchIcon3",
                    "clickAction": "act_back"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 13,
                    "marginLeft": 110,
                    "forceCaps": false,
                    "fontSize": 18,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "$COLOR_WHITE",
                    "text": "Back"
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "MenuLayout",
            "alignV": "TOP",
            "alignH": "FILL",
            "marginTop": 40,
            "height": 30,
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 70,
                    "fontSize": 38,
                    "fontFace": "$FONT_EAFCGAMEMODES",
	                "fontColor": "0xFFFFFF",
	                "text": "MC"
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "forceCaps": false,
                    "marginLeft": 155,
                    "fontSize": 20,
                    "fontFace": "$FONT_CRUYFFSANSBOLD",
                    "fontColor": "0xFFFFFF",
                    "text": "Central"
                },
                {
                    "commonName": "Rectangle",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 260,
                    "width": 2,
                    "height": 23,
                    "color": "0xA8A8A8",
                    "alpha": 1
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 290,
                    "fontSize": 20,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "0xAAAAAA",
                    "text": "Standings"
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "UIFrame",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": 10,
            "width": 900,
            "height": 450,
            "children":
            [
                {
                    "commonName": "Rectangle",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "cornerRaduis": 20,
                    "color": "0x1B1B2A",
                    "alpha": 1
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "FILL",
                    "height": 54,
                    "alpha": 0.5,
                    "type": "$_RectangleTop"
                },
                {
                    "commonName": "Image",
                    "name": "LeagueLogo",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 7,
                    "marginLeft": 27,
                    "width": 232,
                    "height": 40,
                    "bindings":
                    [
                        {
                            "binding": "bnd_league_logo",
                            "property": "image"
                        }
                    ]
                },
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 65,
                    "marginLeft": 0,
                    "width": 900,
                    "fontSize": 19,
                    "fontColor": "$COLOR_WHITE",
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "text": "          Pos                   Club                                                                              Played    Won     Draw     Lost      GA         GD        Pts            "
                },
                {
                    "commonName": "Panel",
                    "name": "TableMatch",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "children":
                    [
                        {
                            "commonName": "VerticalList",
                            "name": "matchlist",
                            "alignV": "TOP",
                            "alignH": "LEFT",
                            "marginTop": 99,
                            "marginLeft": 0,
                            "displayRange": 7,
                            "highlightable": true,
                            "row": "StandingsRow",
                            "rowHeight": 50,
                            "rowWidth": 910,
                            "bindings":
                            [
                                {
                                    "binding": "bnd_match_list",
                                    "property": "dataProviders"
                                 }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
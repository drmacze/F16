{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "children":
    [
        {
            "commonName": "Panel",
            "name": "UIFrame",
            "alignV": "FILL",
            "alignH": "FILL",
            "children":
            [
                {
                    "commonName": "Panel",
                    "name": "Tab",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 430,
                    "marginTop": 5,
                    "width": 335,
                    "height": 375,
                    "children":
                    [
                        {
                            "commonName": "Rectangle",
                            "alignV": "FILL",
                            "alignH": "FILL",
                            "fillColor": "0x1B1B2A",
                            "fillAlpha": 0,
                            "drawFill": true,
                            "drawOutline": true,
                            "outlineThickness": 0.8,
                            "outlineColor": "0x00D9D1",
                            "outlineAlpha": 1,
                            "cornerRaduis": 9
                        }
                    ]
                },
                {
                    "commonName": "Panel",
                    "name": "Action",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 60,
                    "marginLeft": 430,
                    "height": 42,
                    "width": 335,
                    "children":
                    [
                        {
                            "commonName": "SimpleButton",
                            "alignH": "CENTER",
                            "alignV": "FILL",
                            "width": 180,
                            "backgroundImage": "$_ClickToEnterOn2",
                            "backgroundHighlightImage": "$_ClickToEnterOn2",
                            "clickAction": "act_restart"
                        },
                        {
                            "commonName": "Label",
                            "alignV": "CENTER",
                            "alignH": "CENTER",
                            "marginLeft": 5,
                            "marginBottom": -1,
                            "width": 170,
                            "autoScroll": true,
                            "fontSize": 17,
                            "fontColor": "0xFFFFFF",
                            "fontFace": "$FONT_CRUYFFSANSMEDIUM",
                            "text": "Reset Career"
                        }
                    ]
                }
            ]
        }
    ]
}
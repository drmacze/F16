{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "SIMPLE_SCREEN_SHOW"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "SIMPLE_SCREEN_HIDE"
                }
            ]
        }
    ],
    "children":

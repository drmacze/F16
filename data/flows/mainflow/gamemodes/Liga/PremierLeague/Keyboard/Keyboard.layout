            "width": 1020,
            "height": 80,
            "children":
            [
                {
                    "commonName": "Rectangle",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "cornerRaduis": 0,
                    "color": "0x1C1C1C",
                    "alpha": 0.6
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",

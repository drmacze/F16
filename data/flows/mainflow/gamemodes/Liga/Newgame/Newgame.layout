                    "children":
                    [
                        {
                            "commonName": "Label",
                            "name": "Text",
                            "alignV": "TOP",
                            "alignH": "LEFT",
                            "marginTop": 19,
                            "marginLeft": 24,
                            "fontSize": 33,
                            "fontColor": "0xFFFFFF",
                            "fontFace": "$FONT_CRUYFFSANSBOLD",
                            "leading": 1,
                            "text": "Create New\nManager"
                        },
                        {
                            "commonName": "Label",
                            "name": "Text",
                            "alignV": "TOP",
                            "alignH": "LEFT",
                            "marginTop": 100,
                            "marginLeft": 24,
                            "fontSize": 14,
                            "fontColor": "0xFFFFFF",
                            "fontFace": "$FONT_CRUYFFSANSREGULAR",
                            "leading": 1,
                            "text": "Take the reins at your favourite club. Apply your\nTactical Vision and lead them to success.\nBalance their performance with meeting the club's\nstrategic and business objectives."
                        }
                    ]
                },
                {
                    "commonName": "Panel",
                    "name": "Info2",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "bindings":

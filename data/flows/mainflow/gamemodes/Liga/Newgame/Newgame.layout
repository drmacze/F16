                    "text": "Back"
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "BgInfo",
            "alignV": "CENTER",
            "alignH": "LEFT",
            "marginLeft": 100,
            "marginTop": -15,
            "width": 600,
            "height": 325,
            "children":
            [
                {
                    "commonName": "Asset",
                    "alignV": "CENTER",
                    "alignH": "CENTER",
                    "marginLeft": 590,
                    "marginTop": 260,
                    "width": 300,
                    "height": 190,

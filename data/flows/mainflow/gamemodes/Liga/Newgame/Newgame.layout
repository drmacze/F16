                            "alignH": "LEFT",
                            "marginTop": 65,
                            "marginLeft": 24,
                            "fontSize": 14,
                            "fontColor": "0xFFFFFF",
                            "fontFace": "$FONT_CRUYFFSANSREGULAR",
                            "leading": 1,
                            "text": "Continue your journey in management. Pick up\nwhere you left off and take your team even further,\nfacing new challenges on and off the pitch."

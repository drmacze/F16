{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name" : "show",
		    "script" : [ { "anim" : "SCREEN_SHOW" } ]
	    },
	    {
		    "name" : "hide",
		    "script" : [ { "anim" : "SIMPLE_SCREEN_HIDE" } ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "SquadCustomizationBehavior",
            "actionName": "act_btn_click",
            "buttonContainer": "BtnClick"
        },
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "",
            "actionName": "act_back",
            "label": ""
	    }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$_Background_2"
        },
        {
            "commonName": "Panel",
            "name": "Back",
            "alignV": "FILL",
            "alignH": "FILL",
            "children":

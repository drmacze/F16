                            "marginTop": 19,
                            "marginLeft": 24,
                            "fontSize": 33,
                            "fontColor": "0xFFFFFF",
                            "fontFace": "$FONT_CRUYFFSANSBOLD",
                            "leading": 1,
                            "text": "Load Manager"
                        },

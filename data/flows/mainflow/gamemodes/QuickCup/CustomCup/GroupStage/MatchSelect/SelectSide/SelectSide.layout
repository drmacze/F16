{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name" : "show",
		        "script" : [ { "anim" : "SCREEN_SHOW" } ]
		    },
		    {
		       	"name" : "hide",
		       	"script" : [ { "anim" : "SIMPLE_SCREEN_HIDE" } ]
	      }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$Bg_Kick"
        },
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "alpha": 0.3,
            "type": "$Bg_Smoke"
        },
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$Icon_SelectSides"
        },
        {
            "commonName": "Panel",
            "name": "UIFrame",
            "alignV": "CENTER",
            "alignH": "FILL",
            "height": 580,
            "children":
            [
               {
                    "commonName": "GenericButton",
                    "alignH": "LEFT",
                    "alignV": "BOTTOM",
                    "marginBottom": 0,
                    "marginLeft": 30,
                    "scaleX": 0.6,
                    "scaleY": 0.6,
                    "icon": "$SimMatchIcon2",
                    "clickAction": "act_back"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 0,
                    "marginLeft": 86,
                    "fontSize": 14,
                    "fontColor": "$COLOR_LIGHT_GRAY",
                    "styles": ["TF_MATCH_REVEAL_TEAM_NAME"],
                    "text": "Back"
                },
                {
                    "commonName": "GenericButton",
                    "alignH": "LEFT",
                    "alignV": "BOTTOM",
                    "marginBottom": 0,
                    "marginLeft": 130,
                    "scaleX": 0.6,
                    "scaleY": 0.6,
                    "icon": "$SimMatchIcon1",
                    "clickAction": "act_advance"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 0,
                    "marginLeft": 185,
                    "fontSize": 14,
                    "fontColor": "$COLOR_LIGHT_GRAY",
                    "styles": ["TF_MATCH_REVEAL_TEAM_NAME"],
                    "text": "Confirm"
                }
			]
		},
    {
      "commonName": "Panel",
      "name": "UIFrame",
      "alignV": "TOP",
      "alignH": "LEFT",
	  "marginLeft": 30,
	  "marginTop": 7,
      "children": [
        {
          "commonName": "Panel",
          "name": "panel0Group",
          "alignV": "CENTER",
          "alignH": "CENTER",
          "alpha": 0,
          "bindings": [
            {
              "binding": "bnd_panel1_visible",
              "property": "Visible"
            }
          ],
          "animationScripts": [
            {
              "name": "animateCount0",
              "script": [
                {
                  "type": "Direct",
                  "data": {
                    "end": {
                      "alpha": 0,
                      "marginLeft": -50
                    },
                    "duration": 100
                  }
                },
                {
                  "type": "Delay",
                  "data": {
                    "duration": 300
                  }
                },
                {
                  "type": "Direct",
                  "data": {
                    "end": {
                      "alpha": 1,
                      "scaleX": 1,
                      "scaleY": 1,
                      "marginLeft": 0
                    },
                    "duration": 800,
                    "easing": "OutBack"
                  }
                }
              ]
            }
          ],
          "children": [
        {
          "commonName": "Asset",
          "alignV": "TOP",
          "alignH": "LEFT",
          "height": 80,
          "width": 80,
          "marginTop": 0,
          "marginLeft": 20,
          "alpha": 1,
          "type": "$Icon_Ko"
        }
          ]
        }
      ],
      "behaviors": [
        {
          "commonName": "TriggerScriptBehavior",
          "name": "trigger_fadein_all",
          "script": "animateCount0",
          "target": "panel0Group"
        },
        {
          "commonName": "TriggerOnTrue",
          "name": "trigger_on_true_all",
          "target": "trigger_fadein_all",
          "bindings": [
            {
              "binding": "bnd_animate_count0",
              "property": "value"
            }
          ]
        }
      ]
    },


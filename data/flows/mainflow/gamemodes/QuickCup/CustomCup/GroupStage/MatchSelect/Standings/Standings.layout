{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
       "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "style-definitions": {
    "TF_TABS_IDLE": {
      "alignH": "LEFT",
      "fontFace": "$Title",
      "fontSize": 22,
      "fontColor": "$COLOR_LIGHT_GRAY",
      "alpha": 0.5,
      "width": 200
    },
    "TF_TABS_HIGHLIGHT": {
      "alignH": "LEFT",
      "fontFace": "$Title",
      "fontSize": 22,
      "fontColor": "$COLOR_WHITE"
    },
    "TF_TABS_SELECTED": {
      "alignH": "LEFT",
      "fontFace": "$Title",
      "fontSize": 22,
      "fontColor": "$COLOR_WHITE",
      "alpha": 1
    }
  },
  "behaviors":

                    "event": "evt_back",
                    "targets": ["out_exit_gamemode1"]
                },
                {
                    "event": "evt_advance",
                    "targets": ["SelectSideFlow"]
                },
                {
                    "event": "evt_to_sim_match",
                    "targets": ["SimulateMatch"]
                },
                {
                    "event": "evt_squad",
                    "targets": ["Squad"]
                },
                {
                    "event": "evt_topscores",

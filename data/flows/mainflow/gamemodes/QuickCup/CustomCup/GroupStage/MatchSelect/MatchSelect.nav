        {
			"name": "SimulateMatch",
			"type": "external",
			"file": "/flows/mainflow/GameModes/QuickCup/CustomCup/PlaySim/Match.nav",
			"outputs":
            {
				"out_back": "MatchSelect"
            }
        },
        {
            "name": "SelectSideFlow",
            "type": "external",
            "file": "/Flows/MainFlow/GameModes/QuickCup/CustomCup/GroupStage/MatchSelect/SelectSide/SelectSide.nav",
            "outputs":
            {
                "out_exit_gamemode": "MatchSelect",
                "out_exit_gamemode1": "MatchSelect"
            }
        },
        {
            "name": "Squad",
            "type": "external",
            "file": "/flows/MainFlow/GameModes/QuickCup/CustomCup/Squad/Squad.nav",
            "outputs":
            {
                "out_exit_gamemode": "RedirectTab2"
            }
        },
        {
            "name": "GoalScores",
            "type": "external",
            "file": "/flows/MainFlow/GameModes/QuickCup/CustomCup/GroupStage/MatchSelect/Goalscorers/Goalscorers.nav",
            "outputs": 
            {
                "out_exit_gamemode": "RedirectTab3sub2",
                "out_exit_gamemode1": "RedirectTab3sub2"
            }
        },
        {
            "name": "Standing",
            "type": "external",
            "file": "/Flows/MainFlow/GameModes/QuickCup/CustomCup/GroupStage/MatchSelect/Standings/Standings.nav",
            "outputs":
            {
                "out_exit_gamemode": "RedirectTab3sub1",
                "out_exit_gamemode1": "RedirectTab3sub1"
            }
        },
        {
            "name": "StandingHome",
            "type": "external",
            "file": "/Flows/MainFlow/GameModes/QuickCup/CustomCup/GroupStage/MatchSelect/Standings/Standings.nav",
            "outputs":
            {
                "out_exit_gamemode": "RedirectTab1",
                "out_exit_gamemode1": "RedirectTab1"
            }
        },
        {
            "name": "Restart",
            "type": "external",
            "file": "/Flows/MainFlow/GameModes/QuickCup/CustomCup/Restart/Restart.nav",
            "outputs":
            {
                "out_exit_gamemode": "out_exit_gamemode1"
            }
        }
    ]
}
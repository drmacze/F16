{
    "name": "QuickCup",
    "initial":
    {
        "targets": ["MenuQuickCup"]
    },
    "states":
    [
		{
            "name": "MenuQuickCup",
            "onEnter":
            [
                ["blockingLoadVVM", ["QuickCup.vvm"]]
            ],
            "onExit":
            [
                ["unloadVVM"]
            ],
            "transitions":
            [
                {
                    "event": "evt_back",
                    "targets": ["out_exit_gamemode1"]
                }
            ]
        }
    ]
}
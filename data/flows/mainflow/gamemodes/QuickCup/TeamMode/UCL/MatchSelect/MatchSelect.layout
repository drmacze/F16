{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$SimMatchIcon3",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
            "commonName": "Image",
            "alignV": "FILL",
            "alignH": "FILL",
            "bindings":
            [
                {
                    "binding": "bnd_cup_bg",
                    "property": "image"
                }
			]
        },
        {
            "commonName": "Panel",
            "name": "Back",
            "alignV": "FILL",
            "alignH": "FILL",
            "children":
            [
                {
                    "commonName": "GenericButton",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": -2,
                    "marginLeft": 50,
                    "height": 50,
                    "width": 50,
                    "label": "",
                    "icon": "$SimMatchIcon3",
                    "clickAction": "act_back"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 13,
                    "marginLeft": 110,
                    "forceCaps": false,
                    "fontSize": 18,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "$COLOR_WHITE",
                    "text": "Back"
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "MenuLayout",
            "alignV": "TOP",
            "alignH": "FILL",

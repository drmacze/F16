                    "fontColor": "0xFFFFFF",
                    "text": "Home"
                },
                {
                    "commonName": "Rectangle",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 245,
                    "width": 2,
                    "height": 23,
                    "color": "0xA8A8A8",
                    "alpha": 1   
                }
            ]
        },
        {
            "commonName": "Panel",

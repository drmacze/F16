{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_BACKGROUND_SYSTEM"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": ""
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "",
            "actionName": "act_back",
            "label": ""
         },
         {
            "commonName": "SquadCustomizationBehavior",
            "actionName": "act_selected",
            "buttonContainer": "selectedButton"
        }
    ],
    "style-definitions":
    {
		"TF_TEAM_SELECT_RATING_LABELS": {
			"fontFace": "$FONT_CRUYFFSANSREGULAR",
			"fontSize": 17,
			"fontColor": "0xFFFFFF",
			"textAlignH": "CENTER",
			"alpha": 1
		},
		"TF_TEAM_SELECT_RATING_VALUES": {
			"fontFace": "$FONT_CRUYFFSANSREGULAR",
			"fontSize": 25,
			"fontColor": "0x00C21B",
			"textAlignH": "CENTER",
			"alpha": 1

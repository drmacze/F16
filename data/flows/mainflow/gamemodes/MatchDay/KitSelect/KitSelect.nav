{
    "name": "KitSelect",
    "initial":
    {
        "targets": ["KitSelectStartMatch"]
    },
    "states":
    [
        {
            "name": "KitSelectStartMatch",
            "onEnter":
            [
                ["blockingLoadVVM", ["KitSelectStartMatch.vvm"]]
            ],
            "onExit":
            [
                ["unloadVVM"]
            ],
            "transitions":
            [
                {
                    "event":   "evt_advance",
                    "targets": ["PlayMatch"]
                },
                {
                    "event":   "evt_back",
                    "targets": ["out_exit_gamemode"]
                },
                {
                    "event":   "evt_refresh_on_resize",
                    "targets": ["KitSelectStartMatch"]
                },
                {
                    "event":   "evt_squad",
                    "targets": ["SquadReal"]
                },
                {
                    "event":   "evt_squadaway",
                    "targets": ["SquadReal"]
                }
            ]
        },
        {
            "name": "PlayMatch",
            "type": "external",
            "file": "/Flows/MainFlow/GameModes/MatchDay/PlayMatch/Match.nav",
            "outputs":
            {
                "out_exit_gamemode": "out_exit_gamemode1"
            }
        },
        {
            "name": "SquadReal",
            "type": "external",
            "file": "/flows/mainflow/gamemodes/matchday/squad/squad.nav",
            "outputs":
            {
                "out_exit_gamemode": "KitSelect"
            }
        }
    ]
}

{
	"commonName": "Panel",
	"alignH": "FILL",
	"alignV": "FILL",
	"name": "insOuterContainer",
	"animationScripts":
	[
		{
			"name" : "show",
			"script" :
			[
				{
					"anim" : "TUTORIAL_TRANSITION_IN"
				}
			]
		},
		{
			"name" : "hide",
			"script" :
			[
				{
					"anim" : "TUTORIAL_TRANSITION_OUT"
				}
			]
		}
	],
	"behaviors":
	[
		{
			"commonName": "SquadTeamManagementBehavior",
            "starting11": "insSquad.insSquadContainer.insSquadLayout",
            "subsAndReserves": "squadSubsContainer.insItemDock",
            "actionName": "act_swap_players"
		},
		{
			"commonName": "SquadPlayerComparisonBehavior",
            "comparisonTargetNames": [
            "insSquad.insSquadContainer.insSquadLayout",
            "squadSubsContainer.insItemDock"
            ],
            "actionName": "act_compare_players"
        },
		{
			"commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$",
            "actionName": "act_advance",
            "label": ""
        }
    ],
	"style-definitions":
	{
		"TF_TEAM_NAME":
		{
            "text-format": "fow.style.SquadStyle.TF_FORMATION_NAME",
            "fontColor": "$COLOR_WHITE",
            "textAlignH": "CENTER"
		},
		"TF_TEAM_NAME1":
		{
            "fontFace": "$Italic",
            "fontColor": "$COLOR_WHITE",

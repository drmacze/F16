                    "commonName": "GenericButton",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": -2,
                    "marginLeft": 50,
                    "height": 50,
                    "width": 50,
                    "label": "",
                    "icon": "$SimMatchIcon3",
                    "clickAction": "act_back"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 13,
                    "marginLeft": 110,
                    "forceCaps": false,
                    "fontSize": 18,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "$COLOR_WHITE",
                    "text": "Back"
                }
            ]
        },
        {
           "commonName": "Label",
           "alignV": "CENTER",
           "alignH": "CENTER",
           "marginLeft": 0,
           "marginTop": -255,
           "fontSize": 33,
           "fontColor": "$COLOR_WHITE",
           "fontFace": "$FONT_CRUYFFSANSHEAVY",
           "text": "SELECT LEAGUE TEAM"
       },
       {
           "commonName": "Label",
           "alignV": "CENTER",
           "alignH": "CENTER",
           "textAlignH": "CENTER",
           "marginLeft": 0,
           "marginTop": -210,
           "width": 700,
           "multiline":true,
           "fontSize": 16,
           "leading": 3,
           "fontColor": "$COLOR_WHITE",
           "fontFace": "$FONT_CRUYFFSANSREGULAR",
           "text": "Choose which leagues you would like to see simulated to the same level of detail as the competitions you are playing in. Cup competitions of participating teams will also be simulated.",
           "alpha": 0.7
       },
       {
           "commonName": "Label",
           "alignV": "CENTER",
           "alignH": "CENTER",
           "textAlignH": "CENTER",
           "marginLeft": 0,
           "marginTop": 170,
           "width": 450,
           "multiline":true,
           "fontSize": 13,
           "leading": 3,
           "fontColor": "$COLOR_WHITE",
           "fontFace": "$FONT_CRUYFFSANSMEDIUM",
           "text": "Please note that adding leagues impacts the career advancement speed. While adding check schedule, later in the seasons impacts the initialization time.",
           "alpha": 0.7
       },
       {
           "commonName": "Label",
           "alignV": "CENTER",

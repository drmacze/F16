{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "style-definitions":
    {
		"TF_LIVE_TILE_HEADLINE_BOLD_SMALL":
        {
			"fontFace": "$FONT_CRUYFFSANSREGULAR",
		    "textAlignH": "LEFT",
            "forceCaps": true,
            "bold": false,
			"fontSize": 17,
			"fontColor": "0xFF767676",
			"leading": 0
	    },
		"TF_LIVE_TILE_HEADLINE_SMALL": 
        {
			"fontFace": "$FONT_CRUYFFSANSHEAVY",
			"fontSize": 20,
			"fontColor": "$COLOR_WHITE",
			"leading": 0
        },
        "TF_CONTEXT_MENU_ROW":
        {
			"fontFace": "$FONT_CRUYFFSANSHEAVY",
            "forceCaps": true,
			"fontSize": 25,
			"fontColor": "0xFFFFFF",
			"leading": 0
		},
		"TF_LIVE_TILE_HEADLINE_BOLD_HIGHLIGHTED_SMALL": 
        {
			"fontFace": "$FONT_CRUYFFSANSHEAVY",
			"fontSize": 20,
			"fontColor": "$0xFF767676",
			"leading": -4
		},
		"TF_LIVE_TILE_HEADLINE_HIGHLIGHTED_SMALL":
        {
			"fontFace": "$FONT_CRUYFFSANSHEAVY",
			"fontSize": 20,
		    "fontColor": "$COLOR_MEDIUM_GRAY",
			"leading": 0
        }
    },
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "",
            "actionName": "act_back",
            "label": ""
	    }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",

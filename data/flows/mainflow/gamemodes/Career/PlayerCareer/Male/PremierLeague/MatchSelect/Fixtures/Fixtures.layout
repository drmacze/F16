{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "",
            "actionName": "act_back",
            "label": ""
        }
    ],
    "children":
    [    
        {  
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$"
        },
        {
            "commonName": "Panel",
            "name": "Back",
            "alignV": "FILL",
            "alignH": "FILL",
            "children":
            [
                {
                    "commonName": "GenericButton",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": -2,
                    "marginLeft": 50,
                    "height": 50,
                    "width": 50,
                    "label": "",
                    "icon": "$SimMatchIcon3",
                    "clickAction": "act_back"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 13,
                    "marginLeft": 110,
                    "forceCaps": false,
                    "fontSize": 18,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "$COLOR_WHITE",
                    "text": "Back"
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "MenuLayout",
            "alignV": "TOP",
            "alignH": "FILL",
            "marginTop": 40,
            "height": 30,
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 70,
                    "fontSize": 38,
                    "fontFace": "$FONT_EAFCGAMEMODES",
	                "fontColor": "0xFFFFFF",
	                "text": "PC"
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "forceCaps": false,
                    "marginLeft": 155,
                    "fontSize": 20,
                    "fontFace": "$FONT_CRUYFFSANSBOLD",
                    "fontColor": "0xFFFFFF",
                    "text": "Office"
                },
                {
                    "commonName": "Rectangle",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 247,
                    "width": 2,
                    "height": 23,
                    "color": "0xA8A8A8",
                    "alpha": 1
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 278,
                    "fontSize": 20,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "0xAAAAAA",
                    "text": "Match Fixtures"
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "UIFrame",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": 10,
            "marginLeft": 0,
            "width": 900,
            "height": 450,
            "children":
            [
                {
                    "commonName": "Rectangle",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "cornerRaduis": 20,
                    "color": "0x1B1B2A",
                    "alpha": 0.8
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "FILL",
                    "height": 54,
                    "alpha": 0.5,
                    "type": "$_RectangleTop"
                },
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 20,
                    "marginLeft": 75,
                    "fontSize": 16,
                    "fontFace": "$FONT_CRUYFFSANSHEAVY",
                    "fontColor": "$COLOR_WHITE",
                    "forceCaps": true,
                    "bold": false,
                    "text": "Premier League"
                },
                {
                    "commonName": "Image",
                    "name": "LeagueLogo",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 7,
                    "marginLeft": 27,
                    "width": 40,
                    "height": 40,
                    "bindings":
                    [
                        {
                            "binding": "bnd_logo_league",
                            "property": "image"
                        }
                    ]
                },
                {
                    "commonName": "Panel",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "children":
                    [
                        {
                            "commonName": "VerticalList",
                            "name": "matchlist",
                            "alignV": "TOP",
                            "alignH": "LEFT",
                            "marginTop": 57,
                            "marginLeft": 12,
                            "displayRange": 8,
                            "highlightable": true,
                            "row": "FixturesBeapro",
                            "rowHeight": 49,
                            "rowWidth": 910,
                            "bindings":
                            [
                                {
                                     "binding": "bnd_match_list",
                                     "property": "dataProviders"
                                }
                            ]
                         }
                      ]
                   }
                ]
             }
          ]
       }
    ]
 }
{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
       "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$SimMatchIcon3",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {          
            "commonName": "Panel",
            "alignV": "FILL",
            "alignH": "FILL",
            "marginTop": 120,
            "marginBottom": 120,
            "marginLeft": 150,
            "marginRight": 150,
            "children":
            [
                {
                    "commonName": "Grid",
                    "name": "TilesGrid",
                    "alignH": "FILL",
                    "alignV": "FILL",
                    "spacingH": "$TILE_PADDING",
                    "spacingV": "$TILE_PADDING",
                    "columns":
                    [
                        {
                            "sizing": "FILL"
                        },
                        {
                            "sizing": "FILL"
                        }
                    ],
                    "layout":
                    [
                        {
                            "child": "controls_help_tile",
                            "column": 0,
                            "row": 0,
                            "colSpan": 1,
                            "rowSpan": 2
                        }
                    ],
                    "rows":
                    [
                        {
                            "sizing": "FILL"
                        },
                        {
                            "sizing": "FILL"
                        },
                        {
                            "sizing": "FILL"
                        }
                    ],
                    "children":
                    [
                        {
                            "commonName": "LiveTile",
                            "name": "controls_help_tile",
                            "alignH": "FILL",
                            "alignV": "FILL",
                            "autoScaleImageToTileHeight":true,
                            "clickAction": "act_to_controls_help_hub",
                            "bindings":
                            [
                                {
                                    "binding": "bnd_controls_help",
                                    "property": "dataProviders"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
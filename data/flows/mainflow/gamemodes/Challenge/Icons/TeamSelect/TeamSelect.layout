{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_IN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "TUTORIAL_TRANSITION_OUT"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$",
            "actionName": "act_back",
            "label": ""
        }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$_Background_2"
        },
        {
            "commonName": "Panel",
            "name": "Back",
            "alignV": "FILL",
            "alignH": "FILL",
            "children":
            [
                {
                    "commonName": "GenericButton",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": -2,
                    "marginLeft": 50,
                    "height": 50,
                    "width": 50,
                    "label": "",
                    "icon": "$SimMatchIcon3",
                    "clickAction": "act_back"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 13,
                    "marginLeft": 110,
                    "forceCaps": false,
                    "fontSize": 18,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "$COLOR_WHITE",
                    "text": "Back"
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "ModeInfo",
            "alignV": "TOP",
            "alignH": "FILL",
            "marginTop": 40,
            "height": 30,
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 75,
                    "fontSize": 38,
                    "fontFace": "$FONT_EAFCGAMEMODES",
	                "fontColor": "0xFFFFFF",
	                "text": "CL"
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "forceCaps": false,
                    "marginLeft": 155,
                    "fontSize": 20,
                    "fontFace": "$FONT_CRUYFFSANSBOLD",
                    "fontColor": "0xFFFFFF",
                    "text": "Challenge"
                },
                {
                    "commonName": "Rectangle",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "marginLeft": 280.6,
                    "width": 2,
                    "height": 23,
                    "color": "0xAAAAAA"
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "LEFT",
                    "forceCaps": false,
                    "marginLeft": 310.6,
                    "fontSize": 20,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "0xAAAAAA",
                    "text": "Select Team"
                }
            ]
        },
        {
            "commonName": "Panel",
            "name": "BagianMenu",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": 10,
            "marginLeft": 0,
            "width": 750,
            "height": 450,
            "children":
            [
                {
                    "commonName": "Rectangle",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "cornerRaduis": 13,
                    "color": "0x1B1B2A",
                    "alpha": 0.8
                },
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 20,
                    "marginLeft": -220,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontSize": 20,
                    "fontColor": "$COLOR_WHITE",
                    "text": "Team:"
                 },
                 {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 20,
                    "marginLeft": 190,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontSize": 20,
                    "fontColor": "$COLOR_WHITE",
                    "text": "Rating:"
                 },
                 {
                    "commonName": "VerticalList",
                    "name": "teamlist",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 70,
                    "marginLeft": -260,
                    "x": 0,
                    "y": 0,
                    "displayRange": 6,
                    "rowChangeAction": "act_team_select",
                    "highlightable": true,
                    "row": "TeamSelectRow",
                    "rowHeight": 70,
                    "rowWidth": 650,
                    "bindings":
                    [
                       {
                           "binding": "bnd_team_list",
                           "property": "dataProviders"
                        }
                     ]
                  }
                ]
             }
           ]
         }
      ]
    }
  ]
}
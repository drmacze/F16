{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "SCREEN_SHOW"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "SIMPLE_SCREEN_HIDE"
                }
            ]
        }
    ],
    "children":
    [
        {
            "commonName": "Rectangle",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": -33,
            "marginLeft": 315,
            "width": 350,
            "height": 30,
            "cornerRaduis": 10,
            "alpha": 1,
            "color": "0xffffff"
         },
         {
            "commonName": "SimpleButton",
            "alignH": "CENTER",
            "alignV": "CENTER",
            "marginTop": -33,
            "marginLeft": 210,
            "height": 28,
            "width": 110,
            "scaleY": 1,
            "multiline": true,
            "bold": true,
            "label": "Touch controls",
            "icon": "",
            "backgroundImage": "",
            "backgroundHighlightImage": "",
            "clickAction": "act_select_touch_controls",
             "textStyles":
            [
               "TF_BUTTON_CONTROLOFF"
            ]
        },
        {
            "commonName": "SimpleButton",
            "alignH": "CENTER",
            "alignV": "CENTER",
            "marginTop": -33,
            "marginLeft": 385,
            "height": 28,
            "width": 110,
            "scaleY": 1,
            "multiline": true,
            "bold": true,
            "label": "Controller controls",
            "icon": "",
            "backgroundImage": "",
            "backgroundHighlightImage": "",
            "clickAction": "act_select_controller_controls",
             "textStyles":
            [
               "TF_BUTTON_CONTROLOFF"
            ]
        },
        {
            "commonName": "BigBinaryToggle",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": -800000,
            "marginLeft": 68,
            "styles": ["TF_LABEL_CENTERED"],
            "visible":    true,
            "onLabel":          "LTXT_MOB_SETTINGS_CONTROLLER",
            "onSelectedIcon":   "$CONTROL_ICON_GAMEPAD_GREY",
            "onUnselectedIcon": "$CONTROL_ICON_TOUCHPAD_WHITE",
            "onAction":         "act_select_touch_controls",
            "offLabel":         "LTXT_MOB_SETTINGS_VIRTUAL",
            "offUnselectedIcon":"$CONTROL_ICON_GAMEPAD_WHITE",
            "offSelectedIcon":  "$CONTROL_ICON_TOUCHPAD_GREY",
            "offAction":        "act_select_controller_controls",
            "bindings":
            [
                {
                     "property": "isOn",
                     "binding":  "bnd_is_touch_control"
                 }
              ]
           }
        ]
     }
  ]
}
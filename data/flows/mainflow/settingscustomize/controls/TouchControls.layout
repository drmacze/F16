{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": ""
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": ""
                }
            ]
        }
    ],
    "children":
    [
        {
            "commonName": "SimpleButton",
            "alignH": "CENTER",
            "alignV": "TOP",
            "marginTop": 90,
            "marginLeft": -330,
            "height": 28,
            "width": 110,
            "scaleY": 1,
            "multiline": true,
            "bold": true,
            "label": "Controls",
            "icon": "",
            "backgroundImage": "",
            "backgroundHighlightImage": "",
            "clickAction": "act_to",
             "textStyles":
            [
               "TF_BUTTON_PLAYMODEON"
            ]
        },
        {
            "commonName": "SimpleButton",
            "alignH": "CENTER",
            "alignV": "CENTER",
            "marginTop": -33,
            "marginLeft": 210,
            "height": 28,
            "width": 110,
            "scaleY": 1,
            "multiline": true,
            "bold": true,
            "label": "Touch controls",
            "icon": "",
            "backgroundImage": "",
            "backgroundHighlightImage": "",
            "clickAction": "act_to",
             "textStyles":
            [
               "TF_BUTTON_CONTROLON"
            ]
        },
        {
            "commonName": "Panel",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "height": 580,
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 120,
                    "marginLeft": 237,
                    "fontSize": 23,
                    "fontColor": "$COLOR_WHITE",
                    "fontFace": "$FONT_CRUYFFSANSBOLD",
                    "text": "Control Settings"
                },
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 160,
                    "marginLeft": 298,
                    "width": 300,
                    "fontSize": 15,
                    "fontColor": "$COLOR_LIGHT_GRAY",
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "text": "Here you can change control settings. virtual button, controller, button position and player skill."
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 280,
                    "marginLeft": 315,
                    "width": 320,
                    "height": 190,
                    "type": "$_Controls_Settings"
                }
            ]
        },
        {
            "commonName": "Panel",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": -20,
            "marginLeft": -180,
            "height": 300,
            "width": 580,
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 8,
                    "marginLeft": 0,
                    "fontSize": 20,
                    "fontColor": "$COLOR_WHITE",
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "text": "Control Scheme"
                },
                {
                    "commonName": "Stack",
                    "name": "PengaturanControlScheme",
                    "alignV": "TOP",
                    "alignH": "RIGHT",
                    "marginTop": 5,
                    "marginRight": 3,
                    "width": 250,
                    "children":
                    [
                        {
                            "commonName": "DragToggle",
                            "alignH": "FILL",
                            "marginTop": -10,
                            "isCircular": true,
                            "itemStyleName": "TF_SETTINGS_ROW_TOGGLE",
                            "itemType": "Label",
                            "maskContent": true,
                            "hasArrows": true,
                            "arrowType" : "blue_medium",
                            "toggleAction":
                            {
                                  "action": "act_change_control_scheme_option",
                                  "binding": "bnd_control_scheme_index"
                            },
                            "bindings":
                            [
                                {
                                    "binding": "bnd_control_scheme_options",
                                    "property": "dataProviders"
                                },
                                {
                                    "binding": "bnd_enable_control_scheme",
                                    "property": "active"
                                }
                            ]
                        }
                    ]				
                }
            ]
        },
        {
            "commonName": "Panel",
            "alignV": "CENTER",
            "alignH": "FILL",
            "height": 580,
            "children":
            [
                {
                    "commonName": "VerticalList",
                    "name": "PengaturanMatch",
                    "alignH": "CENTER",
                    "alignV": "CENTER",
                    "marginTop": -125,
                    "marginLeft": -500,
                    "rowWidth": 630,
                    "rowHeight": 60,
                    "displayRange": 7,
                    "useAlternating": false,
                    "row": "CustomizationRow",
                    "bindings":
                    [
                        {
                            "binding": "bnd_touch_controls_list_data",
                            "property": "dataProviders"
                        }
                    ]
                 }
             ]
         }
     ]
}
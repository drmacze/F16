{
"animationScripts":
	[
		{
			"name" : "show",
			"script" :
			[
				{
					"anim" : "OVERLAY_TRANSITION_IN"
				}
			]
		},
		{
			"name" : "hide",
			"script" :
			[
				{
					"anim" : "OVERLAY_TRANSITION_OUT"
				}
			]
     }
	],
   "commonName": "Overlay",
    "title":"CONFIRM"
    "footer":
    [
        {
            "icon":        "$FooterIconNo",
            "clickAction": "act_cancel",
            "label":"CANCEL"
        },
        {
            "icon":        "$FooterIconYes",
            "clickAction": "act_confirm",
            "label":"CONTINUE"
        }
    ],
    "children":
    [
        {
			"commonName": "Label",
			"name":       "insDescLbl",
			"x":          25,
			"y":          20,
			"width":      560,
			"multiline":  true,
			"wordWrap":   true,
			"styles":     ["TF_LABEL_CENTERED"],
			"bindings":
			[
				{
					"property": "text",
					"binding":  "bnd_message"
				}
			]
		}
    ]
}

                    "commonName": "GenericButton",
                    "alignH": "LEFT",
                    "alignV": "BOTTOM",
                    "marginBottom": -15,
                    "marginLeft": 140,
                    "scaleX": 0.9,
                    "scaleY": 0.9,
                    "label": "",
                    "icon": "$SimMatchIcon4",
                    "clickAction": "act_accept"
                }
            ]
        },
        {
           "commonName": "Panel",
            "name": "Menu",
            "alignV": "FILL",
            "alignH": "FILL",
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 37,
                    "marginLeft": 55,
                    "fontSize": 27,
                    "fontFace": "$FONT_CRUYFFSANSBOLD",
                    "fontColor": "$COLOR_WHITE",
                    "text": "Game Settings"
                  }
              ]
         },
         {
            "commonName": "SimpleButton",
            "alignH": "CENTER",
            "alignV": "TOP",

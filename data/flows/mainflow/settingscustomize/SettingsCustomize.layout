         },
         {
            "commonName": "Panel",
            "name": "BackSave",
            "alignV": "CENTER",
            "alignH": "FILL",
            "height": 580,
            "children":
            [
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": -12,
                    "marginLeft": 98,
                    "fontSize": 18,
                    "fontFace": "$FONT_CRUYFFSANSREGULAR",
                    "fontColor": "$COLOR_WHITE",
                    "text": "Back"
                },
                {
                    "commonName": "GenericButton",
                    "alignH": "LEFT",
                    "alignV": "BOTTOM",
                    "marginBottom": -15,
                    "marginLeft": 8,
                    "scaleX": 0.9,
                    "scaleY": 0.9,
                    "label": "",

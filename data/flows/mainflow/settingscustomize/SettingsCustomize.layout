{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "SCREEN_SHOW"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "SIMPLE_SCREEN_HIDE"
                }
            ]
        }
    ],
    "style-definitions":
    {
        "TF_RIGHT_PANEL":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_MEDIUM",
            "fontColor": "$COLOR_LIGHT_GRAY",
            "textAlignH": "CENTER",
            "leading": -2.0
        },
        "TF_AUDIO_TITLE":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_MEDIUM",
            "fontColor": "$COLOR_LIGHT_GRAY"
        },
        "TF_OPTIONS":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_LARGEST",
            "fontColor": "$COLOR_LIGHT_BLUE",
            "resizeType": "NONE"
        },
        "TF_OPTIONS_RIGHT":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_LARGEST",
            "fontColor": "$COLOR_LIGHT_BLUE",
            "textAlignH": "RIGHT"
        },
        "TF_TITLE":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_SMALL_HEADER",
            "fontColor": "$COLOR_DARK_BLUE",
            "textAlignH": "RIGHT"
        },
        "TF_GENERAL_TITLE":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_LARGE_HEADER",
            "fontColor": "$COLOR_DARK_BLUE"
        },
        "TF_SETTINGS_ROW_LABEL":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": 20,
            "fontColor": "$COLOR_WHITE",
            "textAlignH": "LEFT"
        },
        
        "TF_SETTINGS_ROW_LABEL_DISABLED":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_MEDIUM_HEADER",
            "fontColor": "$COLOR_MEDIUM_GRAY",
            "textAlignH": "LEFT"
        },
        "TF_SETTINGS_ROW_TOGGLE":
        {
            "fontFace": "$FONT_CRUYFFSANSHEAVY",
            "fontSize": 16,
            "forceCaps": true,
            "fontColor": "$COLOR_WHITE",
            "textAlignH": "CENTER",
            "textAlignV": "CENTER",
            "leading": 1
        },
        "TF_GENERAL_TEXT":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_MEDIUM",
            "fontColor": "$COLOR_LIGHT_GRAY"
        },
        "TF_MULTILINE_TEXT":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": "$FONT_SIZE_LARGEST",
            "fontColor": "$COLOR_LIGHT_GRAY",
            "leading": 0.1
        },
        "TF_CUSTOMIZE_INGAME_WARNING":
        {
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "fontSize": 14.0,
            "fontColor": "$COLOR_BLUE"
        }
    },
    "children":
    [

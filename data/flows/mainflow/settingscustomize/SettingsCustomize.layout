        {
            "commonName": "SimpleButton",
            "alignH": "CENTER",
            "alignV": "TOP",
            "marginTop": 90,
            "marginLeft": 45,
            "height": 28,
            "width": 110,
            "scaleY": 1,
            "multiline": true,
            "bold": true,
            "label": "User Info",
            "icon": "",
            "backgroundImage": "",

            "clickAction": "act_select_user",
             "textStyles":
            [
               "TF_BUTTON_PLAYMODEOFF"
            ]
        },
        {
            "commonName": "TabBar",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": -245000000,
            "width": 1000,
            "tabs":
            [
                {
                    "label": "Gameplay",
                    "clickAction": "act_select_match_settings"
                },
                {
                    "label": "Controls",
                    "clickAction": "act_select_controls"
                },
                {
                    "label": "Audio",
                    "clickAction": "act_select_audio_visual"               
                },
                {
                    "label": "Graphics",
                    "clickAction": "act_select_debug_settings"
                },
                {
                    "label": "User",
                    "clickAction": "act_select_user"
                }
            ],
            "bindings":
            [
                {
                    "binding": "bnd_settings_customize_tab_index",
                    "property": "selectedIndex"
                }
            ]
        },
        {
            "commonName": "Layer",

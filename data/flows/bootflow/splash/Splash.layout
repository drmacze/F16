{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_SPLASHSCREEN"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_SPLASHSCREEN"
                }
            ]
        }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$_Splash_Screen"
        },
        {
            "commonName": "Rectangle",
            "alignV": "FILL",
            "alignH": "FILL",
            "color": "0x000000",
            "alpha": 0
         },
         {
            "commonName": "Asset",
            "alignV": "CENTER",
            "alignH": "LEFT",
            "width": 650,
            "height": 650,
            "visible": true,
            "alpha": 1,
            "type": "$_Model_Screen"
         },
         {
            "commonName": "Label",
            "alignH": "CENTER",
            "alignV": "CENTER",
            "marginTop": -180,
            "marginLeft": 163,
            "fontSize": 55,
            "fontColor": "0xFFFFFF",
            "fontFace": "$ArchivoBlack-Regular",
            "text": "EA SPORTS FC 27",
            "textAlignH": "LEFT",
            "width": 500,
            "leading": 1.5,
            "alpha": 1
         },
         {
            "commonName": "Label",
            "alignH": "CENTER",
            "alignV": "CENTER",
            "marginTop": -30,
            "marginLeft": 200,
            "fontSize": 18,
            "fontColor": "0xFFFFFF",
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "text": "Take charge of your team to victory as head coach, build your squad, and lead your team through challenging seasons and tournaments. This project was designed by Rober FL and modified by THORK 9INE . Everyone can download and enjoy the game. Don't forget to subscribe to THORK 9INE and Rober FL channel.",
            "textAlignH": "LEFT",
            "width": 500,
            "leading": 1.5,
            "alpha": 1
         },
         {
            "commonName": "Panel",
            "name": "Action",
            "alignV": "BOTTOM",
            "alignH": "CENTER",
            "marginBottom": 140,
            "marginLeft": 50,
            "width": 350,
            "children":
            [
                {
                    "commonName": "SimpleButton",
                    "alignH": "CENTER",
                    "alignV": "CENTER",
                    "marginLeft": 0,
                    "marginTop": -10,
                    "height": 42,
                    "width": 180,
                    "backgroundImage": "$_ClickToEnterOn2",
                    "backgroundHighlightImage": "$_ClickToEnterOn2",
                    "clickAction": "act_press_start"
                },
                {
                    "commonName": "Label",
                    "alignV": "CENTER",
                    "alignH": "CENTER",
                    "marginLeft": 5,
                    "marginBottom": 9,
                    "fontSize": 17,
                    "fontColor": "0xFFFFFF",
                    "fontFace": "$FONT_CRUYFFSANSMEDIUM",
                    "text": "Let's Play!"
                }
            ]
        },
        {
            "commonName": "Asset",
            "alignV": "BOTTOM",
            "alignH": "RIGHT",
            "marginBottom": 20,
            "marginRight": 20,
            "width": 50,
            "height": 50,
            "path": "views/loadingindicator/loadingIcon.swf"
         },
         {
            "commonName": "Label",
            "alignH": "CENTER",
            "alignV": "BOTTOM",
            "marginBottom": 20,
            "marginLeft": 120,
            "fontSize": 15,
            "fontColor": "0xDADADA",
            "fontFace": "$FONT_CRUYFFSANSREGULAR",
            "text": "©Copyright 2026 THORK 9INE.\nFC 27 is a project was created and distributed by Rober FL and modified by THORK 9INE.",
            "textAlignH": "LEFT",
            "width": 500,
            "leading": 1.5
          }
        ]
      }
   ]
}


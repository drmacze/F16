{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "animationScripts":
    [
        {
            "name" : "show",
		    "script" : [ { "anim" : "SCREEN_SHOW" } ]
	    },
	    {
			"name" : "hide",
		    "script" : [ { "anim" : "SIMPLE_SCREEN_HIDE" } ]
	    }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$SimMatchIcon4",
            "actionName": "act_advance",
            "label": "Advance"
        }
    ],
    "children":
    [
       {
           "commonName": "Rectangle",
           "alignV": "FILL",
           "alignH": "FILL",
     	  "alpha": 0.8,
           "color": "0x000000"
       },
       {
            
      "commonName": "Panel",
      "name": "MenuLayout",
      "alignV": "CENTER",
      "alignH": "CENTER",
      "marginLeft": 0,
      "marginTop": -100,
      "width": 400,
      "height": 50,
      "children": [
        {
          "commonName": "Image",
          "alignV": "CENTER",
          "alignH": "CENTER",
          "marginTop": -110,
          "width": 450,
          "image": "$FadedDividerLine"
        }
      ]
    },
    {
      "commonName": "Panel",
      "name": "MenuLayout",
      "alignV": "CENTER",
      "alignH": "CENTER",
      "marginLeft": 0,
      "marginTop": -100,
      "width": 400,
      "height": 400,
      "children": [
        {
          "commonName": "Panel",
          "name": "panel1Group",
          "alignV": "CENTER",
          "alignH": "CENTER",
          "alpha": 0,
          "bindings": [
            {
              "binding": "bnd_panel1_visible",
              "property": "Visible"
            }
          ],
          "animationScripts": [
            {
              "name": "animateCount1",
              "script": [
                {
                  "type": "Direct",
                  "data": {
                    "end": {
                      "alpha": 0,
                      "marginTop": -60
                    },
                    "duration": 100
                  }
                },
                {
                  "type": "Delay",
                  "data": {
                    "duration": 300
                  }
                },
                {
                  "type": "Direct",
                  "data": {
                    "end": {
                      "alpha": 1,
                      "scaleX": 1,
                      "scaleY": 1,
                      "marginTop": -80
                    },
                    "duration": 900,
                    "easing": "OutElastic"
                  }
                }
              ]
            }
          ],
          "children": [
            {
              "commonName": "Label",
              "name": "MatchResultsTitle",
              "alignV": "CENTER",
              "alignH": "CENTER",
              "marginTop": -50,
              "marginLeft": 0,
              "fontSize": 30,
              "fontColor": "$COLOR_WHITE",
              "fontFace": "$FONT_CRUYFFSANSBOLD",
              "text": "MATCH RESULTS"
            }
          ]
        }
      ],
      "behaviors": [
        {
          "commonName": "TriggerScriptBehavior",
          "name": "trigger_fadein_all",
          "script": "animateCount1",
          "target": "panel1Group"
        },
        {
          "commonName": "TriggerOnTrue",
          "name": "trigger_on_true_all",
          "target": "trigger_fadein_all",
          "bindings": [
            {
              "binding": "bnd_animate_count1",
              "property": "value"
            }
          ]
        }
      ]
    },
    {
      "commonName": "Panel",

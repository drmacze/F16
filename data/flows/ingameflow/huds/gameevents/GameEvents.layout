									"property": "fontSize",
									"binding":  "bnd_title_fontSize"
								},
								{
									"property": "fontColor",
									"binding":  "bnd_title_fontColor"
								}
                            ]
                        }
                    ]
                },
                {
                    "commonName": "Panel",
                    "alignH": "CENTER",
                    "alignV": "CENTER",
                    "bindings":
                    [
                        {
                            "property": "height",
                            "binding":  "bnd_logo_height"
                        },
                        {
                            "property": "width",
                            "binding":  "bnd_logo_width"
                        },
                        {
                            "property": "marginTop",
                            "binding":  "bnd_logo_top"
                        },
                        {
                            "property": "marginLeft",
                            "binding":  "bnd_logo_left"
                        }
                    ],
                    "children":
                    [
                        {
                            "commonName": "Rectangle",
							"alignH": "FILL",
							"alignV": "FILL",
							"bindings":
                            [
								{
									"property": "color",
									"binding":  "bnd_logo_color"
								},
                                {
                                    "property": "alpha",
                                    "binding":  "bnd_event_alpha"
                                },
                                {
                                    "property": "visible",
                                    "binding":  "bnd_logo_color_visible"
                                }
							]
                        },
                        {
                            "commonName": "Image",
							"alignV": "CENTER",
                            "alignH": "CENTER",
                            "bindings":
                            [
                                {
                                    "binding": "bnd_logo_outside_visible",
                                    "property": "visible"
                                },
                                {
									"property": "image",
									"binding":  "bnd_logo"
								},
                                {
                                    "property": "height",
                                    "binding":  "bnd_logoheight"
                                },
                                {
                                    "property": "width",
                                    "binding":  "bnd_logowidth"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
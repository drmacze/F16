{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "TOP",
            "alignH": "FILL",
            "height": 65,
            "type": "$BackgroundHitam"
        },
        {
            "commonName": "Asset",
            "alignV": "BOTTOM",
            "alignH": "FILL",
            "height": 65,
            "type": "$BackgroundHitam"
        }
    ]
}
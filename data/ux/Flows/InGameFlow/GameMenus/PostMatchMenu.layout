                        {
                            "commonName": "Image",
                            "name": "LogoTimAway",
                            "alignV": "CENTER",
                            "alignH": "RIGHT",
                            "marginRight": 10,
                            "scaleX": 0.37,
                            "scaleY": 0.37,

                },

                {
                    "commonName": "Panel",
                    "name": "BagianMatchFacts",
                    "alignV": "BOTTOM",
                    "alignH": "RIGHT",
                    "width": 447,
                    "height": 345,
                    "children":
                    [
                        {
                            "commonName": "Asset",
                            "alignV": "FILL",
                            "alignH": "FILL",
                            "type": "$LiveTileBackgroundIdle"
                        },
                        {
                            "commonName": "VerticalList",
                            "rowWidth": 447,
                            "rowHeight": 38,
                            "divider": "$Divider",
                            "row": "GameMenuRows",
                            "useAlternating": true,
                            "bindings":
                            [
                                {
                                    "binding": "bnd_match_facts",
                                    "property": "dataProviders"
                                }
                            ]
                        }
                    ]
                },
                
                {
                    "commonName": "Panel",
                    "name": "BagianMenu",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "width": 447,
                    "height": 345,
                    "children":
                    [
                        {
                            "commonName": "LiveTile",
                            "name": "MenuMatchFacts&Events",
                            "alignV": "TOP",
                            "alignH": "LEFT",
                            "width": 447,
                            "height": 111,
                            "clickAction": "act_to_match_facts",
                            "autoScaleImageToTileHeight": true,
                            "images":
                            [
                               "$IconMatchFact"
                            ],
                            "bindings":
                            [
                               {
                                   "binding": "bnd_live_tile_matchfacts",
                                   "property": "headline"
                               }
                            ]
                        },
                        {
                            "commonName": "LiveTile",
                            "name": "MenuMatchHighlights",
                            "alignV": "CENTER",
                            "alignH": "LEFT",
                            "width": 447,
                            "height": 111,
                            "clickAction": "act_to_match_highlights",
                            "autoScaleImageToTileHeight": true,
                            "images":
                            [
                               "$IconInstantReplay"
                            ],
                            "bindings":
                            [
                               {
                                   "binding": "bnd_live_tile_matchhighlights",
                                   "property": "headline"
                               }
                            ]
                        },
                        {
                            "commonName": "LiveTile",
                            "name": "MenuRestartMatch",
                            "alignV": "BOTTOM",
                            "alignH": "LEFT",
                            "width": 221,
                            "height": 111,
                            "clickAction": "act_restart_match",
                            "autoScaleImageToTileHeight": true,
                            "images":
                            [
                               "$IconRestartMatch"
                            ],
                            "bindings":
                            [
                               {
                                   "binding": "bnd_live_tile_restart",

                        },
                        {
                            "commonName": "Label",
                            "name": "NamaTimHome",
                            "alignV": "BOTTOM",
                            "alignH": "CENTER",
                            "marginBottom": 7,
                            "marginLeft": -180,
                            "fontSize": 28,
                            "fontColor": "$COLOR_WHITE",
                            "forceCaps": true,
                            "bindings":
                            [
                               {
                                  "binding": "bnd_home_team_name",
                                  "property": "text"
                               }
                            ]
                        },
                        {
                            "commonName": "Label",
                            "name": "NamaTimAway",
                            "alignV": "BOTTOM",
                            "alignH": "CENTER",
                            "marginBottom": 7,
                            "marginRight": -180,
                            "fontSize": 28,
                            "fontColor": "$COLOR_WHITE",
                            "forceCaps": true,
                            "bindings":

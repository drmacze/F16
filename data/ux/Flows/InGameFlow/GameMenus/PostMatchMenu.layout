                               }
                            ]
                        },
                        {
                            "commonName": "LiveTile",
                            "name": "MenuQuitMatch",
                            "alignV": "BOTTOM",
                            "alignH": "RIGHT",
                            "marginRight": -0.3,
                            "width": 221,
                            "height": 111,
                            "clickAction": "act_quit_match",
                            "autoScaleImageToTileHeight": true,
                            "images":
                            [

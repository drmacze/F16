{
    "commonName": "Panel",
    "name": "rootContainer",
	"alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "children":
    [
    
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "alpha": 0.5,
            "type": "$BackgroundHitam"
        },
        
        {
            "commonName": "Panel",
            "name": "MenuPostMatch",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 900,
            "height": 460,
            "children":
            [
                {
                    "commonName": "Panel",
                    "name": "BagianInfoTim&Skor",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "width": 900,
                    "height": 110,
                    "children":
                    [
                        {
                            "commonName": "Asset",
                            "alignV": "FILL",
                            "alignH": "FILL",
                            "type": "$MenuSelection"
                        },
                        {
                            "commonName": "Label",
                            "name": "InfoBabak",
                            "alignV": "TOP",

                       },
                       {
                            "commonName": "Image",
                            "name": "LogoTimHome",
                            "alignV": "CENTER",
                            "alignH": "LEFT",
                            "marginLeft": 10,
                            "scaleX": 0.37,
                            "scaleY": 0.37,
                            "bindings":
                            [
                               {
                                  "binding": "bnd_home_team_crest",
                                  "property": "image"

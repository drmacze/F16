                        {
                            "commonName": "Label",
                            "name": "InfoWaktu",
                            "alignV": "CENTER",
                            "alignH": "CENTER",
                            "marginTop": -15,
                            "fontSize": 22,
                            "fontColor": "$COLOR_WHITE",
                            "bindings":
                            [
                                {
                                    "binding": "bnd_stadium_name",
                                    "property": "text"
                                }
                            ]
                        },
                        {
                            "commonName": "Label",
                            "name": "InfoHasilAduPinalti",
                            "alignV": "CENTER",
                            "alignH": "CENTER",
                            "marginTop": 6.5,
                            "fontSize": 16,
                            "fontColor": "$COLOR_WHITE",
                            "bindings":
                            [
                                {
                                    "binding": "bnd_shootout_result",
                                    "property": "text"

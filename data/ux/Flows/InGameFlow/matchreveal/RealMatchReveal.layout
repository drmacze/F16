        },
        {
            "commonName": "Label",
            "alignV": "TOP",
            "alignH": "RIGHT",
            "marginTop": 310,
            "marginRight": 60,
			"fontFace": "$FONT_KNULMEDIUM",
            "fontSize": 20,
            "fontColor": "$COLOR_WHITE",
            "text": "AWAY"
        },
        {
            "commonName": "Asset",

{ 
    "commonName": "Panel",
	"name": "rootContainer",
    "alignH": "CENTER",
    "alignV": "CENTER",
	"bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "children":
    [
    	{
			"commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$BackgroundDefault"
        },
        {

            "commonName": "Image",
            "name": "insHomeStadium",
            "alignV": "FILL",
            "alignH": "FILL",
            "bindings":
            [
                {
                            "property": "image",
                            "binding":  "bnd_home_stadium_bg"
                }
            ]
        },
    	{
			"commonName": "Asset",

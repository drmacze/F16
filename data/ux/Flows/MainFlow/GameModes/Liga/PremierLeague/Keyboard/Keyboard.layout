/*-- Layout Design MVNPROD YouTube --*/
{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name" : "show",
		        "script" : [ { "anim" : "SCREEN_SHOW" } ]
		    },
		    {
		       	"name" : "hide",
		       	"script" : [ { "anim" : "SIMPLE_SCREEN_HIDE" } ]
	      }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$Bg_Liga"
        },       
        {
            "commonName": "Panel",
            "name": "UIFrame",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": 0,
            "marginLeft": 160,
            "width": 2000,
            "height": 800,
            "children":
            [
                {
                    "commonName": "Rectangle",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "cornerRaduis": 0,
                    "color": "0x2B2B2B",
                    "alpha": 1
                },
                {
                    "commonName": "Rectangle",
                    "alignV": "TOP",
                    "alignH": "FILL",
                    "marginTop": 47,
                    "height": 1,
                    "color": "0xFFFFFF",
                    "alpha": 0.1
                },                
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 233,
                    "marginLeft": -700,
                    "fontSize": 20,
                    "fontColor": "$COLOR_WHITE",
                    "bold": false,
                    "bindings":
                    [
                        {
                            "binding": "bnd_team_label",
                            "property": "text"
                        }
                    ]
                }
            ]
        },

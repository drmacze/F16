{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },
        
        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },
        {
            "commonName": "Panel",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 1000,
            "height": 550,
            "children":
            [
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": -22,
                    "width": 930,
                    "height": 540,
                    "type": "$LiveTileBackgroundIdle"
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": -25,
                    "height": 40,
                    "width": 930,
                    "type": "$BackgroundJudulMenu"
                },
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": -20,
                    "marginLeft": -255,
                    "fontSize": 25,
                    "fontColor": "$COLOR_WHITE",
                    "forceCaps": true,
                    "bindings":
                    [
                        {
                            "binding": "bnd_team_label",
                            "property": "text"
                        }
                    ]
                },
                {
                    "commonName": "GenericButton",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": -20,
                    "marginLeft": 80,
                    "width": 25,
                    "height": 25,
                    "clickAction": "act_previousteam"
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": -25,
                    "marginLeft": 75,
                    "height": 40,
                    "width": 40,
                    "type": "$Panah_Before"
                },
                {
                    "commonName": "GenericButton",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": -20,
                    "marginLeft": 380,
                    "width": 25,
                    "height": 25,
                    "clickAction": "act_nextteam"
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": -25,
                    "marginLeft": 375,
                    "height": 40,
                    "width": 40,
                    "type": "$Panah_After"
                },
                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": -20,
                    "marginRight": -255,
                    "fontSize": 25,
                    "fontColor": "$COLOR_WHITE",
                    "forceCaps": true,
                    "bindings":
                    [
                        {
                            "binding": "bnd_matchday_label",
                            "property": "text"
                        }
                    ]
                },
                {
                    "commonName": "GenericButton",
                    "alignV": "TOP",
                    "alignH": "RIGHT",
                    "marginTop": -20,
                    "marginRight": 380,
                    "width": 25,
                    "height": 25,
                    "clickAction": "act_decrease"
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "RIGHT",
                    "marginTop": -25,
                    "marginRight": 375,
                    "height": 40,
                    "width": 40,
                    "type": "$Panah_Before"
                },
                {
                    "commonName": "GenericButton",
                    "alignV": "TOP",
                    "alignH": "RIGHT",
                    "marginTop": -20,
                    "marginRight": 80,
                    "width": 25,
                    "height": 25,
                    "clickAction": "act_next"
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "RIGHT",
                    "marginTop": -25,
                    "marginRight": 75,
                    "height": 40,
                    "width": 40,
                    "type": "$Panah_After"
                },
                
                {
                    "commonName": "VerticalList",
                    "name": "matchlist",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 20,
                    "marginLeft": -450,
                    "x": 0,
                    "y": 0,
                    "displayRange": 7,
                    "highlightable": true,
                    "row": "FixturesRow",
                    "rowHeight": 70.0,
                    "rowWidth": 925,
                    "bindings":
                    [
                        {
                            "binding": "bnd_match_list",
                            "property": "dataProviders"
                        }
                    ]
                }
            ]
        }

    ]
}

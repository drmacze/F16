/* ------------------------------------- */
/* MOD Created By Ma'ruf ID */
/* ------------------------------------- */

{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },
        
        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },
        {
            "commonName": "Panel",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 1000,
            "height": 550,
            "children":
            [
                 {
                    "commonName": "GridTable",
                    "name": "leaguesGridTable",
                    "alignV": "TOP",
                    "alignH": "RIGHT",
                    "marginTop": 50,
                    "marginRight": -50,
                    "height": 478,
                    "width": 750,
                    "alpha": 1.3,
                    "color": "$COLOR_WHITE",
                    
                    "cellIndexChangeAction":
                    {
                        "action": "act_change",
                        "binding": "bnd_player_index"
                    },
                    "columns": 7,
                    "hasBulletIndicator": true,
                    "itemType": "LeagueGridCell",
                    "rows": 5,
                    "bindings":
                    [
                        {
                            "binding": "bnd_player_list",
                            "property": "dataProviders"
                        },
                        {
                            "binding": "bnd_default_cell_data",
                            "property": "defaultCellData"
                        }
                    ]
                 },
                 {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 50,
                    "marginLeft": -50,
                    "width": 277,
                    "height": 460,
                    "type": "$BackgroundPilihTim"
                 },
                {
                    "commonName": "Panel",
                    "name": "BagianInfo",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 50,
                    "marginLeft": -50,
                    "width": 277,
                    "height": 460,
                    "children":
                    [
                            {
                                "commonName": "Label",
                                "alignV": "TOP",
                                "alignH": "CENTER",
                                "marginTop": 10,
                                "fontSize": 20,
                                "fontColor": "$COLOR_DARK_GRAY",
                                "text": "SCHEDULE"
                            },
                            {
                                "commonName": "Label",
                                "alignV": "TOP",
                                "alignH": "CENTER",
                                "marginTop": 40,
                                "fontSize": 30,
                                "width": 260,
                                "fontColor": "$COLOR_DARK_GRAY",
                                "text": "2015/16 SEASON"
                            },
                            {
                                "commonName": "Label",
                                "alignV": "BOTTOM",
                                "alignH": "CENTER",
                                "marginBottom": 51.5,
                                "marginRight": 22,
                                "fontSize": 20,
                                "fontColor": "$COLOR_DARK_GRAY",
                                "bindings":
                                    [
                                       {
                                          "binding": "bnd_groundcol1",
                                          "property": "text"
                                       }
                                    ]
                            },
                            {
                                "commonName": "Label",
                                "alignV": "BOTTOM",
                                "alignH": "CENTER",
                                "marginBottom": 51.5,
                                "marginRight": 8,
                                "fontSize": 20,
                                "fontColor": "$COLOR_DARK_GRAY",
                                "bindings":
                                    [
                                       {
                                          "binding": "bnd_groundcol2",
                                          "property": "text"
                                       }
                                    ]
                            },
                            {
                                "commonName": "Label",
                                "alignV": "BOTTOM",
                                "alignH": "CENTER",
                                "marginBottom": 51.5,
                                "marginLeft": 8,
                                "fontSize": 20,
                                "fontColor": "$COLOR_DARK_GRAY",
                                "bindings":
                                    [
                                       {
                                          "binding": "bnd_groundcol3",
                                          "property": "text"
                                       }
                                    ]
                            },
                            {
                                "commonName": "Label",
                                "alignV": "BOTTOM",
                                "alignH": "CENTER",
                                "marginBottom": 51.5,
                                "marginLeft": 22,
                                "fontSize": 20,
                                "fontColor": "$COLOR_DARK_GRAY",
                                "bindings":
                                    [
                                       {
                                          "binding": "bnd_groundcol4",
                                          "property": "text"
                                       }
                                    ]
                            },
                            {
                                "commonName": "Image",
                                "name": "logoteam",
                                "alignV": "TOP",
                                "alignH": "CENTER",
                                "marginTop": 120,
                                "width": 170,
                                "height": 170,
                                "bindings":
                                    [
                                       {
                                          "binding": "bnd_teamcrest",
                                          "property": "image"
                                       }
                                    ]
                            },
                            {
                                "commonName": "Label",
                                "alignV": "BOTTOM",
                                "alignH": "CENTER",
                                "width": 260,
                                "marginBottom": 10,
                                "fontSize": 30,
                                "fontColor": "$COLOR_DARK_GRAY",
                                "forceCaps": true,
                                "autoScroll": true,
                                "bindings":
                                    [
                                       {
                                          "binding": "bnd_teamname",
                                          "property": "text"
                                       }
                                    ]
                            },
                            {
                                "commonName": "Label",
                                "alignV": "BOTTOM",
                                "alignH": "CENTER",
                                "width": 260,
                                "marginBottom": 115,
                                "fontSize": 20,
                                "fontColor": "$COLOR_WHITE",
                                "forceCaps": true,
                                "autoScroll": true,
                                "bindings":
                                    [
                                       {
                                          "binding": "bnd_result",
                                          "property": "text"
                                       }
                                    ]
                            }
                    ]
                }
            ]
        }
    ]
}

{
    "name": "Progress",
    "states":
    [
        {
            "name": "RedirectProgress",
            "onEnter":
            [
                ["blockingLoadVVM", ["Next.vvm"]]
            ],
            "onExit":
            [
                ["unloadVVM"]
            ],
            "transitions":
            [
                {
                    "event": "evt_back",
                    "targets": ["out_exit_gamemode"]
                }
            ]
        }
    ]
}
{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },
        
        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },
        {
            "commonName": "Panel",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 1000,
            "height": 550,
            "children":
            [
                    {
                        "commonName": "Asset",
                        "alignV": "CENTER",
                        "alignH": "CENTER",
                        "width": 950,
                        "height": 490,
                        "type": "$Bg_Negosiasi"
                    },
                    {
                        "commonName": "LiveTile",
                        "alignV": "BOTTOM",
                        "alignH": "RIGHT",
                        "marginBottom": 75,
                        "marginRight": 90,
                        "width": 90,
                        "height": 40
                    },
                    {
                        "commonName": "GenericButton",
                        "name": "insSearch",
                        "alignV": "BOTTOM",
                        "alignH": "RIGHT",
                        "marginBottom": 80,
                        "marginRight": 95,
                        "width": 70,
                        "height": 25,
                        "clickAction": "act_search",
                        "icon": "$AuctionHouseSearchIcon",
                        "textStyles":
                            [
                                "TF_AH_BUTTON"
                            ],
                            "bindings":
                            [
                                {
                                    "binding": "bnd_btn_search",
                                    "property": "dataProviders"
                                }
                            ]
                    },       
                    {
                        "commonName": "Asset",
                        "alignV": "BOTTOM",
                        "alignH": "RIGHT",
                        "marginBottom": 75,
                        "marginRight": 90,
                        "width": 90,
                        "height": 40,
                        "type": "$MenuSelection"
                    },
                    {
                        "commonName": "Label",
                        "alignV": "BOTTOM",
                        "alignH": "RIGHT",
                        "marginBottom": 83,
                        "marginRight": 107,
                        "fontSize": 20,
                        "fontColor": "$COLOR_WHITE",
                        "text": "OFFER"
                    },
                    {
                        "commonName": "Label",
                        "alignV": "TOP",
                        "alignH": "LEFT",
                        "marginTop": 52,
                        "marginLeft": 137,
                        "fontSize": 25,
                        "fontColor": "$COLOR_DARK_GRAY",
                        "text": "PLAYER INFO"
                    },
                    {
                        "commonName": "Label",
                        "alignV": "TOP",
                        "alignH": "LEFT",
                        "marginTop": 52,
                        "marginLeft": 625,
                        "fontSize": 25,
                        "fontColor": "$COLOR_DARK_GRAY",
                        "text": "TRANSFER OFFER"
                    },
                    {
                        "commonName": "Label",
                        "alignV": "BOTTOM",
                        "alignH": "RIGHT",
                        "marginBottom": 190,
                        "marginRight": 120,
                        "fontSize": 15,
                        "fontColor": "$COLOR_WHITE",
                        "bindings":
                           [
                             {
                                "binding":"bnd_status_label",
                                "property":"text"
                             }
                           ]
                    },
                    {                        "commonName": "Image",
                        "alignV": "CENTER",
                        "alignH": "LEFT",
                        "marginTop": -35,
                        "marginLeft": 115,
					   	"scaleX": 0.90,
                        "scaleY": 0.90,
                        "bindings":
                           [
                             {
                                "binding":"bnd_player_head",
                                "property":"image"
                             }
                           ]
                    },
                    {
                        "commonName": "Image",
                        "alignV": "CENTER",
                        "alignH": "LEFT",
                        "marginTop": -25,
                        "marginLeft": 280,
					   	"scaleX": 0.40,
                        "scaleY": 0.40,
                        "bindings":
                           [
                             {
                                "binding":"bnd_team_logo",
                                "property":"image"
                             }
                           ]
                    },   
                    {
					   	"commonName": "AmountSelector",
					   	"name": "insAmount4",
                        "alignV": "TOP",
                        "alignH": "RIGHT",
					   	"marginRight": 105,
					   	"marginTop": 215,
					   	"height": 50.0,
					   	"width": 334.0,
					   	"changeAction": "act_max_buy_change",
					   	"decreaseAction": "act_amount_decrease",
					   	"focusOutAction": "act_max_buy_focusOut",
					   	"icon": "",
					   	"id": 4.0,
					   	"inactiveButtons": true,
					   	"increaseAction": "act_amount_increase",
					   	"maxChars": 13.0,
					   	"bindings":
                            [
                                {
                                    "binding": "bnd_maximum_buy_now_price",
                                    "property": "description"
                                },
                                {
                                    "binding": "bnd_max_value",
                                    "property": "maxValue"
                                },
                                {
                                    "binding": "bnd_min_value",
                                    "property": "minValue"
                                },
                                {
                                    "binding": "bnd_max_buy",
                                    "property": "value"
                                },
                                {
                                    "binding": "bnd_amount_any",
                                    "property": "zeroLabel"
                                }
                            ]
                    }
            ]
        }
                  
    ]
}
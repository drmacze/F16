{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },
        
        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },
        {

{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },
        
        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },
        {
            "commonName": "Panel",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 1000,
            "height": 550,
            "children":
            [
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 90,
                    "width": 930,
                    "height": 395,
                    "type": "$LiveTileBackgroundIdle"
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "RIGHT",
                    "marginTop": 90,
                    "width": 150,
                    "height": 395,
                    "type": "$MenuSelection"
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 49,
                    "width": 930,
                    "height": 40,
                    "type": "$BackgroundJudulMenu"
                },
                {
                    "commonName": "Asset",
                    "alignV": "TOP",
                    "alignH": "RIGHT",
                    "marginTop": 49,
                    "width": 70,
                    "height": 40,
                    "type": "$BackgroundJudulMenu"
                },



                {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "CENTER",
                    "marginTop": 57,
                    "fontSize": 25,
                    "fontColor": "$COLOR_WHITE",
                    "text": "SELECT PLAYERS"
                },
                 {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 105,
                    "marginLeft": 170,
                    "fontSize": 17,
                    "fontColor": "$COLOR_DARK_GRAY",
                    "text": "NAME"
                 },
                 {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 105,
                    "marginLeft": 375,
                    "fontSize": 17,
                    "fontColor": "$COLOR_DARK_GRAY",
                    "text": "POS"
                 },
                 {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 105,
                    "marginLeft": 545,
                    "fontSize": 17,
                    "fontColor": "$COLOR_DARK_GRAY",
                    "text": "OVR"
                 },
                 {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 105,
                    "marginLeft": 745,
                    "fontSize": 17,
                    "fontColor": "$COLOR_DARK_GRAY",
                    "text": "TEAM"
                 },
                 {
                    "commonName": "Label",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 105,
                    "marginLeft": 895,
                    "fontSize": 17,
                    "fontColor": "$COLOR_WHITE",
                    "text": "OFFERS"
                 },
                 {
                    "commonName": "VerticalList",
                    "name": "matchlist",
                    "alignV": "TOP",
                    "alignH": "LEFT",
                    "marginTop": 140,
                    "marginLeft": 75,
                    "x": 0,
                    "y": 0,
                    "displayRange": 5,
                    "highlightable": true,
                    "row": "ScoutRow",
                    "rowHeight": 67.5,
                    "rowWidth": 935,
                    "bindings":
                    [
                        {
                            "binding": "bnd_match_list",
                            "property": "dataProviders"
                        }
                    ]
                }
             ]
         }
    ]
}

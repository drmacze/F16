/* ------------------------------------- */
/* MOD Created By Ma'ruf ID */
/* ------------------------------------- */

{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },
        
        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },
        {
            "commonName": "Panel",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 1000,
            "height": 550,
            "children":
            [

                {
                    "commonName": "GridTable",
                    "name": "leaguesGridTable",
                    "height": 404,
                    "width": 600,
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 67.5,
                    "marginLeft": -50,
                    "color": "$COLOR_WHITE",
                    "alpha": 1.3,
                    "cellIndexChangeAction": {
                        "action": "act_change",
                        "binding": "bnd_player_index"
                    },
                    "columns": 2,
                    "hasBulletIndicator": false,
                    "itemType": "LeagueGridCell",
                    "rows": 2,
                    "bindings": [
                        {
                            "binding": "bnd_player_list",
                            "property": "dataProviders"
                        },
                        {
                            "binding": "bnd_default_cell_data",
                            "property": "defaultCellData"
                        }
                    ]
                },
                {
                    "commonName": "Panel",
                    "name": "BagianFormasi",
                    "alignV": "BOTTOM",
                    "alignH": "RIGHT",
                    "marginBottom": 70,
                    "marginRight": -50,
                    "width": 450,
                    "height": 400,
                    "children":
                    [
                          {
                             "commonName": "LiveTile",
                             "alignV": "CENTER",
                             "alignH": "CENTER",
                             "width": 450,
                             "height": 400,
                             "clickAction": "act_squad"
                          },
                          {
                             "commonName": "Asset",
                             "alignV": "TOP",
                             "alignH": "CENTER",
                             "width": 450,
                             "height": 290,
                             "marginTop": 40,
                             "type": "$MenuSelection"
                          },
                          {
                             "commonName": "Asset",
                             "alignV": "TOP",
                             "alignH": "CENTER",
                             "height": 40,
                             "width": 450,
                             "type": "$BackgroundJudulMenu"
                          },
                          {
                             "commonName": "Label",
                             "alignV": "TOP",
                             "alignH": "CENTER",
                             "marginTop": 5,
                             "fontSize": 25,
                             "fontColor": "$COLOR_WHITE",
                             "bindings": [
                                    {
                                      "binding": "bnd_sheetname",
                                      "property": "text"
                                    }
                                ]
                          },
		                  {
			                 "commonName": "Asset",
			                 "alignV": "BOTTOM",
			                 "alignH": "CENTER",
                             "marginBottom": 70,
			                 "width": 330,
			                 "height": 250,
			                 "type": "$Pitch"
		                  },
                          {
			                 "commonName": "Label",
			                 "alignV": "BOTTOM",
			                 "alignH": "CENTER",
                             "marginBottom": 15,
			                 "fontSize": 35,
			                 "fontColor": "$COLOR_DARK_GRAY",
			                 "text": "CHECK LINE UP"
                          },
                          {
                             "commonName": "Image",
                             "name": "playerteam",
                             "alignH": "CENTER",
                             "alignV": "CENTER",
                             "scaleX": 0.6,
                             "scaleY": 0.6,
                             "bindings": [
                                    {
                                      "binding": "bnd_crest",
                                      "property": "image"
                                    }
                                ]
                          }
                    ]
                }
            
        
        
        
        
            ]
        }
    ]
}
/*-- Layout Design MVNPROD YouTube --*/
/* ------------------------------------- */

{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [

        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },

        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },

        {
            "commonName": "Panel",
            "name": "BagianMenu",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 700,
            "height": 450,
            "children":
            [
                {
                   "commonName": "Asset",
                   "alignV": "FILL",
                   "alignH": "FILL",
                   "type": "$LiveTileBackgroundIdle"
                },
                {
                   "commonName": "Asset",
                   "alignV": "TOP",
                   "alignH": "FILL",
                   "height": 40,
                   "type": "$BackgroundJudulMenu"
                },
                {
                   "commonName": "Label",
                   "alignV": "TOP",
                   "alignH": "CENTER",
                   "marginTop": 5,
                   "fontSize": 25,
			       "fontColor": "$COLOR_WHITE",
			       "text": "SELECT SIDE"
                },
		        {
			       "commonName": "GenericButton",
			       "name": "ButtonSideHome",
			       "alignV": "CENTER",
			       "alignH": "LEFT",
			       "marginTop": -130,
                   "marginLeft": 90,
                   "width": 140,
                   "height": 55,
			       "clickAction": "act_toggle_home",
			       "bindings":
			       [
				      {
					     "binding": "bnd_side_home_icon",
					     "property": "icon"
				      },
			 	      {
					     "binding": "bnd_side_home_label",
					     "property": "label"
				      }
			       ]
		        },
		        {
			       "commonName": "GenericButton",
			       "name": "ButtonSideAway",
			       "alignV": "CENTER",
			       "alignH": "RIGHT",
			       "marginTop": -130,
                   "marginRight": 90,
                   "width": 140,
                   "height": 55,
			       "clickAction": "act_toggle_away",
			       "bindings":
			       [
				      {
					     "binding": "bnd_side_away_icon",
					     "property": "icon"
				      },
			 	      {
					     "binding": "bnd_side_away_label",
					     "property": "label"
				      }
			       ]
		        },

                {
                   "commonName": "Asset",
                   "alignV": "CENTER",
                   "alignH": "CENTER",
                   "marginTop": -130,
                   "width": 80,
                   "height": 50,
                   "alpha": 0.2,
                   "type": "$IconControllerPS4"
                },
                {
                   "commonName": "Asset",
                   "alignV": "CENTER",
                   "alignH": "CENTER",
                   "marginTop": 5,
                   "width": 80,
                   "height": 50,
                   "alpha": 0.2,
                   "type": "$IconControllerPS4"
                },
                {
                   "commonName": "Asset",
                   "alignV": "CENTER",
                   "alignH": "CENTER",
                   "marginTop": 140,
                   "width": 80,
                   "height": 50,
                   "alpha": 0.2,
                   "type": "$IconControllerPS4"
                },
                
                {
                   "commonName": "Label",
                   "alignV": "BOTTOM",
                   "alignH": "CENTER",
                   "marginBottom": 25,
                   "marginLeft": -193,
                   "alpha": 0.5,
                   "fontSize": 40,
			       "fontColor": "$COLOR_DARK_GRAY",
			       "text": "HOME"
                },
                {
                   "commonName": "Label",
                   "alignV": "BOTTOM",
                   "alignH": "CENTER",
                   "marginBottom": 25,
                   "marginRight": -193,
                   "alpha": 0.5,
                   "fontSize": 40,
			       "fontColor": "$COLOR_DARK_GRAY",
			       "text": "AWAY"
                }
            ]
        }
	]
}
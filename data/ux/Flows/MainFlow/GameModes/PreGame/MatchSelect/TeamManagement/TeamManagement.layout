/* ------------------------------------- */

{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
    
        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },
        
        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },
        
        {
            "commonName": "Panel",
            "name": "BagianMenu",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 700,
            "height": 400,
            "children":
            [
                {
                   "commonName": "Asset",
                   "alignV": "FILL",
                   "alignH": "FILL",
                   "alpha": 0.5,
                   "type": "$BackgroundHitam"
                },
                {
                   "commonName": "Asset",
                   "alignV": "TOP",
                   "alignH": "FILL",
                   "height": 40,
                   "type": "$BackgroundJudulMenu"
                },
                {
                   "commonName": "Label",
                   "alignV": "TOP",
                   "alignH": "CENTER",
                   "marginTop": 5,
                   "fontSize": 25,
			       "fontColor": "$COLOR_WHITE",
			       "text": "SELECT YOUR TEAM"
                },
                {
                   "commonName": "Image",
                   "name": "LogoTimHome",
                   "alignV": "TOP",
                   "alignH": "CENTER",
                   "marginTop": 75,
                   "marginLeft": -180,
                   "width": 110,
                   "height": 110,
                   "bindings":
                   [
                      {
                         "binding": "bnd_logo_tim_home",
                         "property": "image"
                      }
                   ]
                },
                {
                   "commonName": "Image",
                   "name": "LogoTimAway",
                   "alignV": "TOP",
                   "alignH": "CENTER",
                   "marginTop": 75,
                   "marginRight": -180,
                   "width": 110,
                   "height": 110,
                   "bindings":
                   [
                      {
                         "binding": "bnd_logo_tim_away",
                         "property": "image"
                      }
                   ]
                },
          
                {
                    "commonName": "Panel",
                    "name": "BagianMenu",
                    "alignV": "FILL",
                    "alignH": "FILL",
                    "children":
                    [

                       {
                          "commonName": "Panel",
                          "name": "MenuTeamManagementHome",
                          "alignV": "CENTER",
                          "alignH": "LEFT",
                          "marginBottom": -55,
                          "marginLeft": 70,
                          "width": 200,
                          "height": 90,
                          "alpha": 2,
                          "children":
                          [
                              {
                                  "commonName": "LiveTile",
                                  "alignV": "FILL",
                                  "alignH": "FILL",
                                  "clickAction": "act_teammanagement_home"
                              },
                              {
                                  "commonName": "Label",
                                  "alignV": "TOP",
                                  "alignH": "CENTER",
                                  "marginTop": 10,
                                  "fontSize": 18,
                                  "fontColor": "$COLOR_DARK_GRAY",
                                  "forceCaps": true,
                                  "bindings":
                                  [
                                     {
                                        "binding": "bnd_nama_tim_home",
                                        "property": "text"
                                     }
                                  ]
                              },
                              {
                                  "commonName": "Asset",
                                  "alignV": "BOTTOM",
                                  "alignH": "CENTER",
                                  "marginBottom": 7,
                                  "width": 50,
                                  "height": 50,
                                  "type": "$IconTeamManagement"
                              }
                          ]
                       },
                       {
                          "commonName": "Panel",
                          "name": "MenuTeamManagementAway",
                          "alignV": "CENTER",
                          "alignH": "RIGHT",
                          "marginBottom": -55,
                          "marginRight": 70,
                          "width": 200,
                          "height": 90,
                          "alpha": 2,
                          "children":
                          [
                              {
                                  "commonName": "LiveTile",
                                  "alignV": "FILL",
                                  "alignH": "FILL",
                                  "clickAction": "act_teammanagement_away"
                              },
                              {
                                  "commonName": "Label",
                                  "alignV": "TOP",
                                  "alignH": "CENTER",
                                  "marginTop": 10,
                                  "fontSize": 18,
                                  "fontColor": "$COLOR_DARK_GRAY",
                                  "forceCaps": true,
                                  "bindings":
                                  [
                                     {
                                        "binding": "bnd_nama_tim_away",
                                        "property": "text"
                                     }
                                  ]
                              },
                              {
                                  "commonName": "Asset",
                                  "alignV": "BOTTOM",
                                  "alignH": "CENTER",
                                  "marginBottom": 7,
                                  "width": 50,
                                  "height": 50,
                                  "type": "$IconTeamManagement"
                              }
                          ]
                       }
                       
                    ]
                },
                
                {
                   "commonName": "Label",
                   "alignV": "BOTTOM",
                   "alignH": "CENTER",
                   "marginBottom": 20,
                   "marginLeft": -180,
                   "fontSize": 50,
			       "fontColor": "$COLOR_WHITE",
			       "autoTextShadow": true,
			       "text": "HOME"
                },
                {
                   "commonName": "Label",
                   "alignV": "BOTTOM",
                   "alignH": "CENTER",
                   "marginBottom": 20,
                   "marginRight": -180,
                   "fontSize": 50,
			       "fontColor": "$COLOR_WHITE",
			       "autoTextShadow": true,
			       "text": "AWAY"
                }

		    ]
	    }
	]
}
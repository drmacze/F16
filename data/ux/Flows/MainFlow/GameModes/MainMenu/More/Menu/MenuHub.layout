/*-- Layout Design MVNPROD YouTube --*/
{
    "commonName": "Panel",
    "alignH": "CENTER",
    "alignV": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        },
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        }
    ],
    "behaviors":
    [
        {
            "commonName": "SquadCustomizationBehavior",
            "actionName": "act_mvnprod",
            "buttonContainer": "MvnprodButton"
        }
    ],
    "animationScripts":
    [
        {
            "name" : "show",
		        "script" : [ { "anim" : "SCREEN_SHOW" } ]
		    },
		    {
		       	"name" : "hide",
		       	"script" : [ { "anim" : "SIMPLE_SCREEN_HIDE" } ]
	      }
    ],
    "children":
    [
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$Bg_Kick"
        },
        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "alpha": 0.2,
            "type": "$Bg_Smoke"
        },
        {
            "commonName": "Panel",
            "name": "UIFrame",
            "alignV": "CENTER",
            "alignH": "FILL",
            "height": 580,
            "children":
            [
               {
                    "commonName": "GenericButton",
                    "alignH": "LEFT",
                    "alignV": "BOTTOM",
                    "marginBottom": 0,
                    "marginLeft": 30,
                    "scaleX": 0.6,
                    "scaleY": 0.6,
                    "icon": "$SimMatchIcon2",
                    "clickAction": "act_back"
                },
                {
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 0,
                    "marginLeft": 86,
                    "fontSize": 14,
                    "fontColor": "$COLOR_LIGHT_GRAY",

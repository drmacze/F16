{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_X",
            "actionName": "act_advance",
            "label": "Select"
        },
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [

        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$BackgroundMainMenu"
        },
        
        {
            "commonName": "Panel",
            "name": "BagianMenu",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 700,
            "height": 500,
            "children":
            [
                {
                   "commonName": "Asset",
                   "alignV": "FILL",
                   "alignH": "FILL",
                   "type": "$LiveTileBackgroundIdle"
                },
                {
                   "commonName": "Asset",
                   "alignV": "TOP",
                   "alignH": "FILL",
                   "height": 40,
                   "type": "$BackgroundJudulMenu"
                },
                {
                   "commonName": "Label",
                   "alignV": "TOP",
                   "alignH": "CENTER",
                   "marginTop": 5,
                   "fontSize": 25,
			       "fontColor": "$COLOR_WHITE",
			       "text": "SELECT TEAMS TO CHECK"
                },

                {
                   "commonName": "Asset",
                   "alignV": "TOP",
                   "alignH": "LEFT",
                   "marginTop": 45.5,
                   "marginLeft": 5,
                   "width": 330,
                   "height": 448.5,
                   "alpha": 0.7,
                   "type": "$BackgroundHitam"
                },
                
                {

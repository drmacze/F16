/* ------------------------------------- */

{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [

        {
            "commonName": "Asset",
            "alignV": "FILL",
            "alignH": "FILL",
            "type": "$BackgroundMainMenu"
        },
        
        {
            "commonName": "Panel",
            "name": "BagianMenu",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "marginTop": -8,
            "width": 860,
            "height": 479,
            "children":
            [
                {
                   "commonName": "Asset",
                   "alignV": "FILL",
                   "alignH": "FILL",
                   "type": "$LiveTileBackgroundIdle"
                },
                {
                   "commonName": "Asset",
                   "alignV": "FILL",
                   "alignH": "FILL",
                   "type": "$Credit"
                },
                {
                   "commonName": "Asset",
                   "alignV": "TOP",
                   "alignH": "FILL",
                   "height": 40,
                   "type": "$BackgroundJudulMenu"
                },
                {
                   "commonName": "Label",
                   "alignV": "TOP",
                   "alignH": "CENTER",
                   "marginTop": 5,
                   "fontSize": 25,
			       "fontColor": "$COLOR_WHITE",
			       "text": "ABOUT MOD"
                }

		    ]
	    }

	]
}
/* ------------------------------------- */

{
    "commonName": "Panel",
    "name": "rootContainer",
    "alignV": "CENTER",
    "alignH": "CENTER",
    "bindings":
    [
        {
            "binding": "BND_SCREEN_WIDTH",
            "property": "width"
        },
        {
            "binding": "BND_SCREEN_HEIGHT",
            "property": "height"
        }
    ],
    "animationScripts":
    [
        {
            "name": "show",
            "script":
            [
                {
                    "anim": "ANIMASI_MASUK_MAINMENU"
                }
            ]
        },
        {
            "name": "hide",
            "script":
            [
                {
                    "anim": "ANIMASI_KELUAR_MAINMENU"
                }
            ]
        }
    ],
    "behaviors":
    [
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_X",
            "actionName": "act_advance",
            "label": "Select"
        },
        {
            "commonName": "TickerNavPublisher",
            "alignH": "LEFT",
            "icon": "$IconButton_O",
            "actionName": "act_back",
            "label": "Back"
        }
    ],
    "children":
    [
    
        {
           "commonName": "Asset",
           "alignV": "FILL",
           "alignH": "FILL",
           "type": "$BackgroundPreGame"
        },

        {
           "commonName": "Asset",
           "alignV": "TOP",
           "alignH": "CENTER",
           "marginTop": 420,
           "marginRight": 20,
           "width": 1500,
           "height": 60,
           "alpha": 0.6,
           "path": "Animasi/Animasi_Adboard_LogoEASports.swf"
        },
        
        {
            "commonName": "Panel",
            "name": "BagianMenu",
            "alignV": "CENTER",
            "alignH": "CENTER",
            "width": 700,
            "height": 450,
            "children":
            [
                {
                    "commonName": "GenericButton",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 8.5,
                    "marginLeft": 30,
                    "height": 65,
                    "width": 80,
                    "clickAction": "act_stadium_previous"
                },
                {
                    "commonName": "GenericButton",
                    "alignV": "BOTTOM",
                    "alignH": "RIGHT",
                    "marginBottom": 8.5,
                    "marginRight": 30,
                    "height": 65,
                    "width": 80,
                    "clickAction": "act_stadium_next"
                },
                {
                   "commonName": "Asset",
                   "alignV": "FILL",
                   "alignH": "FILL",
                   "type": "$LiveTileBackgroundIdle"
                },
                {
                   "commonName": "Asset",
                   "alignV": "TOP",
                   "alignH": "FILL",
                   "height": 40,
                   "type": "$BackgroundJudulMenu"
                },
                {
                   "commonName": "Label",
                   "alignV": "TOP",
                   "alignH": "CENTER",
                   "marginTop": 5,
                   "fontSize": 25,
			       "fontColor": "$COLOR_WHITE",
			       "text": "SELECT STADIUM"
                },
                {
                    "commonName": "Image",
                    "name": "insHomeStadium",
                    "alignH": "CENTER",
                    "alignV": "CENTER",
                    "width": 690,
                    "height": 320,
                    "marginTop": -20,
                    "bindings":
                    [
                        {
                            "binding": "bnd_stadium_bg",
                            "property": "image"
                        }
                    ]                                
                },
                {
                   "commonName": "Asset",
                   "alignV": "BOTTOM",
                   "alignH": "FILL",
                   "height": 80,
                   "type": "$MenuSelection"
                },
				{
                    "commonName": "Label",
                    "alignV": "BOTTOM",
                    "alignH": "CENTER",
                    "marginBottom": 21,
                    "fontSize": 30,
                    "fontColor": "$COLOR_WHITE",
                    "forceCaps": true,
                    "bindings":
                    [
                        
                        {
                            "binding": "bnd_stadium_name",
                            "property": "text"
                        }
                    ]                
                },

                {
                    "commonName": "Asset",
                    "alignV": "BOTTOM",
                    "alignH": "LEFT",
                    "marginBottom": 25,
                    "marginLeft": 56,
                    "width": 26,
                    "height": 28,
                    "type": "$TournamentLeft"
                },
                {
                    "commonName": "Asset",
                    "alignV": "BOTTOM",
                    "alignH": "RIGHT",
                    "marginBottom": 25,
                    "marginRight": 56,
                    "width": 26,
                    "height": 28,
                    "type": "$TournamentRight"
                }
            ]
        }
    ]
}
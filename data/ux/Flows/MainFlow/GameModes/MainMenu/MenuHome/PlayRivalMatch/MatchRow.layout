                            "name": "HomeTeamCrest",
                            "alignV": "CENTER",
                            "alignH": "LEFT",
                            "marginLeft": 20,
                            "width": 75,
                            "height": 75
                        },
                        {
                            "commonName": "Label",
                            "name": "HomeTeamShortName",
                            "alignV": "TOP",
                            "alignH": "CENTER",
                            "marginTop": 15,
                            "marginLeft": -130,
                            "fontSize": 37,
                            "fontColor": "$COLOR_DARK_GRAY"
                        },
                        {
                            "commonName": "Label",
                            "name": "HomeTeamName",
                            "alignV": "BOTTOM",
                            "alignH": "CENTER",
                            "marginBottom": 19,
                            "marginLeft": -130,
                            "fontSize": 18,
                            "fontColor": "$COLOR_DARK_GRAY"
                        },
                        {
                            "commonName": "Label",
                            "alignV": "CENTER",
                            "alignH": "CENTER",
                            "fontSize": 38,
                            "fontColor": "$COLOR_DARK_GRAY",
                            "text": "- VS -"
                        },
                        {
                            "commonName": "Image",
                            "name": "AwayTeamCrest",
                            "alignV": "CENTER",
                            "alignH": "RIGHT",
                            "marginRight": 20,
                            "width": 75,
                            "height": 75
                        },
                        {
                            "commonName": "Label",
                            "name": "AwayTeamShortName",
                            "alignV": "TOP",
                            "alignH": "CENTER",
                            "marginTop": 15,
                            "marginRight": -130,
                            "fontSize": 37,
                            "fontColor": "$COLOR_DARK_GRAY"
                        },
                        {
                            "commonName": "Label",
                            "name": "AwayTeamName",
                            "alignV": "BOTTOM",
                            "alignH": "CENTER",
                            "marginBottom": 19,
                            "marginRight": -130,
                            "fontSize": 18,

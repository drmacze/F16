        "dataProviders.AwayTeamCrest": "RowPanel.RowLeftPanel.AwayTeamCrest.image",
        "dataProviders.AwayTeamName": "RowPanel.RowLeftPanel.AwayTeamName.text",
        "dataProviders.AwayTeamShortName": "RowPanel.RowLeftPanel.AwayTeamShortName.text",
